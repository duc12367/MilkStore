@model MilkStore.Models.Product
@{
    bool isEdit = Model.Id != 0;
    ViewData["Title"] = isEdit ? "Sửa sản phẩm" : "Thêm sản phẩm";
    <link rel="icon" type="image/png" href="~/images/logo-transparent.png" />
}

<div style="max-width:720px">
    <div class="admin-card">
        <div class="admin-card-header">
            <h5>@(isEdit ? " Sửa sản phẩm" : "+ Thêm sản phẩm mới")</h5>
            <a asp-area="Admin" asp-controller="Product" asp-action="Index"
               class="btn-admin" style="background:#f3e5f5;color:#6a1b9a">← Quay lại</a>
        </div>

        <div style="padding:1.5rem">
            <form asp-area="Admin" asp-controller="Product" asp-action="Save"
                  method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input type="hidden" name="Id" value="@Model.Id" />

                <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem">
                    <div style="grid-column:1/-1">
                        <label class="form-label">Tên sản phẩm *</label>
                        <input type="text" name="ProductName" value="@Model.ProductName"
                               class="form-ctrl" required />
                    </div>

                    <div>
                        <label class="form-label">Danh mục *</label>
                        <select name="CategoryId" class="form-ctrl" required>
                            <option value="">-- Chọn danh mục --</option>
                            @foreach (var cat in (List<MilkStore.Models.Category>)ViewBag.Categories)
                            {
                                if (Model.CategoryId == cat.Id)
                                {
                                    <option value="@cat.Id" selected>@cat.Name</option>
                                }
                                else
                                {
                                    <option value="@cat.Id">@cat.Name</option>
                                }
                            }
                        </select>
                    </div>

                    <div>
                        <label class="form-label">Thương hiệu *</label>
                        <select name="BrandId" class="form-ctrl" required>
                            <option value="">-- Chọn thương hiệu --</option>
                            @foreach (var brand in (List<MilkStore.Models.Brand>)ViewBag.Brands)
                            {
                                if (Model.BrandId == brand.Id)
                                {
                                    <option value="@brand.Id" selected>@brand.Name</option>
                                }
                                else
                                {
                                    <option value="@brand.Id">@brand.Name</option>
                                }
                            }
                        </select>
                    </div>

                    <div>
                        <label class="form-label">Giá (đ) *</label>
                        <input type="number" name="Price" value="@Model.Price"
                               class="form-ctrl" required min="0" step="1000" />
                    </div>

                    <div>
                        <label class="form-label">Tồn kho</label>
                        <input type="number" name="StockQuantity"
                               value="@Model.StockQuantity"
                               class="form-ctrl" min="0" />
                    </div>

                    <div>
                        <label class="form-label">Hạn sử dụng</label>
                        <input type="date" name="ExpiryDate"
                               value="@Model.ExpiryDate.ToString("yyyy-MM-dd")"
                               class="form-ctrl" />
                    </div>

                    <div>
                        <label class="form-label">Upload ảnh mới</label>
                        <input type="file" name="imageFile" class="form-ctrl"
                               accept="image/*" onchange="previewImg(this)" />
                    </div>

                    <div style="display:flex;align-items:center">
                        <img id="imgPreview"
                             src="@(string.IsNullOrEmpty(Model.ImageUrl) ? "https://placehold.co/80x80?text=Preview" : Model.ImageUrl)"
                             style="width:80px;height:80px;object-fit:cover;border-radius:8px" />
                        @if (!string.IsNullOrEmpty(Model.ImageUrl))
                        {
                            <input type="hidden" name="ImageUrl" value="@Model.ImageUrl" />
                        }
                    </div>

                    <div style="grid-column:1/-1">
                        <label class="form-label">Mô tả</label>
                        <textarea name="Description" class="form-ctrl" rows="3"
                                  placeholder="Mô tả sản phẩm...">@Model.Description</textarea>
                    </div>
                </div>

                <div style="margin-top:1.5rem;display:flex;gap:.75rem">
                    <button type="submit" class="btn-admin btn-primary-admin"
                            style="padding:.65rem 1.75rem;font-size:.95rem">
                        @(isEdit ? " Lưu thay đổi" : " Thêm sản phẩm")
                    </button>
                    <a asp-area="Admin" asp-controller="Product" asp-action="Index"
                           class="btn-admin" style="background:#f3e5f5;color:#6a1b9a;padding:.65rem 1.25rem">
                        Hủy
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function previewImg(input) {
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = e => document.getElementById('imgPreview').src = e.target.result;
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
}
