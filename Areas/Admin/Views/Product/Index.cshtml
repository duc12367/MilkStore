@model List<MilkStore.Models.Product>
@{
    ViewData["Title"] = "Quản lý kho sản phẩm";
    <link rel="icon" type="image/png" href="~/images/logo-transparent.png" />
}

<div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:1.25rem">
    <div>
        <div class="page-title">Quản lý kho sản phẩm</div>
        <div class="page-sub">Theo dõi tồn kho và quản lý sản phẩm</div>
    </div>
    <a asp-area="Admin" asp-controller="Product" asp-action="Create" class="btn btn-primary">
        <svg viewBox="0 0 20 20" fill="currentColor" style="width:16px;height:16px"><path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd" /></svg>
        Thêm sản phẩm
    </a>
</div>

<!-- Search -->
<div class="card" style="margin-bottom:1.25rem">
    <div class="card-body" style="padding:.875rem 1.25rem">
        <form method="get">
            <div class="search-wrap">
                <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
                <input type="text" name="search" value="@ViewBag.Search" placeholder="Tìm kiếm sản phẩm, thương hiệu..." />
                <button type="submit" class="btn btn-primary btn-sm">Tìm</button>
            </div>
        </form>
    </div>
</div>

<!-- Product list -->
<div style="display:flex;flex-direction:column;gap:.75rem">
    @foreach (var p in Model)
    {
        var stockStatus = p.StockQuantity > 30 ? "Đủ" : p.StockQuantity > 10 ? "Thấp" : p.StockQuantity > 0 ? "Rất thấp" : "Hết";
        var stockColor = p.StockQuantity > 30 ? "#dcfce7;color:#166534" :
                          p.StockQuantity > 10 ? "#fef9c3;color:#854d0e" :
                          p.StockQuantity > 0 ? "#fee2e2;color:#991b1b" : "#f1f5f9;color:#64748b";
        <div class="card">
            <div style="display:flex;align-items:center;gap:1rem;padding:1rem 1.25rem">
                <img src="@(p.ImageUrl ?? "https://placehold.co/80x80/f0f4f8/94a3b8?text=No+img")"
                     style="width:72px;height:72px;object-fit:cover;border-radius:10px;flex-shrink:0;border:1px solid #e2e8f0"
                     onerror="this.src='https://placehold.co/80x80/f0f4f8/94a3b8?text=No+img'" />
                <div style="flex:1;min-width:0">
                    <div style="font-weight:600;font-size:.95rem;color:#0f172a;margin-bottom:.2rem">@p.ProductName</div>
                    <div style="font-size:.8rem;color:#94a3b8">
                        Mã: P@p.Id.ToString("D3") •
                        <span style="color:#0ea5e9">@p.Brand?.Name</span> •
                        @p.Category?.Name
                    </div>
                    <div style="display:grid;grid-template-columns:repeat(3,auto);gap:1.5rem;margin-top:.75rem;align-items:center">
                        <div>
                            <div style="font-size:.72rem;color:#94a3b8;text-transform:uppercase;letter-spacing:.4px;margin-bottom:.2rem">Giá bán</div>
                            <div style="font-weight:700;color:#0f172a">@String.Format("{0:N0}đ", p.Price)</div>
                        </div>
                        <div>
                            <div style="font-size:.72rem;color:#94a3b8;text-transform:uppercase;letter-spacing:.4px;margin-bottom:.2rem">Tồn kho</div>
                            <div style="display:flex;align-items:center;gap:.4rem;font-weight:700;color:#0ea5e9">
                                <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" style="width:14px;height:14px"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" /></svg>
                                @p.StockQuantity
                            </div>
                        </div>
                        <div>
                            <div style="font-size:.72rem;color:#94a3b8;text-transform:uppercase;letter-spacing:.4px;margin-bottom:.2rem">Hạn sử dụng</div>
                            <div style="font-size:.85rem;color:#374151">@p.ExpiryDate.ToString("dd/MM/yyyy")</div>
                        </div>
                    </div>
                </div>
                <div style="display:flex;align-items:center;gap:.75rem;flex-shrink:0">
                    <span class="badge" style="background:@stockColor">
                        @if (stockStatus == "Rất thấp" || stockStatus == "Thấp")
                        {
                            <svg viewBox="0 0 20 20" fill="currentColor" style="width:12px;height:12px"><path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" /></svg>
                        }
                        @stockStatus
                    </span>
                    <a asp-area="Admin" asp-controller="Product" asp-action="Edit" asp-route-id="@p.Id"
                           class="btn btn-ghost btn-sm">
                        <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" style="width:14px;height:14px"><path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" /></svg>
                    </a>
                    <form asp-area="Admin" asp-controller="Product" asp-action="Delete" method="post" style="display:inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@p.Id" />
                        <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Xóa sản phẩm này?')">
                            <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" style="width:14px;height:14px"><path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
                        </button>
                    </form>
                </div>
            </div>
        </div>
    }
</div>

@if (ViewBag.TotalPages > 1)
{
    <div style="display:flex;justify-content:center;gap:.4rem;padding:1.5rem 0">
        @for (int i = 1; i <= ViewBag.TotalPages; i++)
        {
            <a asp-area="Admin" asp-controller="Product" asp-action="Index"
               asp-route-page="@i" asp-route-search="@ViewBag.Search"
               class="btn btn-sm @(ViewBag.Page == i ? "btn-primary" : "btn-ghost")">@i</a>
        }
    </div>
}
