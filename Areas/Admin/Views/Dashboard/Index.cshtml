@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Dashboard";
}

<div class="page-title">MilkStore Dashboard</div>
<div class="page-sub">Tổng quan doanh thu và kinh doanh</div>

<!-- Stat cards -->
<div class="stat-grid">
    <div class="stat-card blue">
        <div class="stat-icon-wrap blue">
            <svg viewBox="0 0 20 20" fill="none" stroke="#0ea5e9" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
        </div>
        <div class="stat-change up">+13.6%</div>
        <div class="stat-label">Tổng doanh thu (Tháng)</div>
        <div class="stat-val" style="font-size:1.3rem">@String.Format("{0:N0}đ", ViewBag.TotalRevenue)</div>
    </div>
    <div class="stat-card green">
        <div class="stat-icon-wrap green">
            <svg viewBox="0 0 20 20" fill="none" stroke="#10b981" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" /></svg>
        </div>
        <div class="stat-change up">+8.2%</div>
        <div class="stat-label">Đơn hàng (7 ngày qua)</div>
        <div class="stat-val">@ViewBag.TotalOrders</div>
    </div>
    <div class="stat-card purple">
        <div class="stat-icon-wrap purple">
            <svg viewBox="0 0 20 20" fill="none" stroke="#8b5cf6" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" /></svg>
        </div>
        <div class="stat-change up">+12.5%</div>
        <div class="stat-label">Khách hàng mới</div>
        <div class="stat-val">@ViewBag.TotalUsers</div>
    </div>
    <div class="stat-card pink">
        <div class="stat-icon-wrap pink">
            <svg viewBox="0 0 20 20" fill="none" stroke="#ec4899" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" /></svg>
        </div>
        <div class="stat-change up">+3.1%</div>
        <div class="stat-label">Tổng sản phẩm</div>
        <div class="stat-val">@ViewBag.TotalProducts</div>
    </div>
</div>

<!-- Tab toggle -->
<div style="display:flex;gap:.5rem;margin-bottom:1.25rem">
    <button class="btn btn-primary btn-sm" id="btn-day" onclick="switchChart('day')">Theo ngày</button>
    <button class="btn btn-ghost btn-sm" id="btn-month" onclick="switchChart('month')">Theo tháng</button>
</div>

<!-- Charts -->
<div style="display:grid;grid-template-columns:2fr 1fr;gap:1.25rem;margin-bottom:1.25rem">
    <div class="card">
        <div class="card-header"><h5>Doanh thu theo ngày</h5></div>
        <div class="card-body"><canvas id="revenueChart" height="200"></canvas></div>
    </div>
    <div class="card">
        <div class="card-header"><h5>Trạng thái đơn hàng</h5></div>
        <div class="card-body"><canvas id="topChart" height="200"></canvas></div>
    </div>
</div>

<!-- Bottom row -->
<div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:1.25rem;margin-bottom:1.25rem">
    <div class="card">
        <div class="card-header"><h5>Sản phẩm bán chạy</h5></div>
        <div class="card-body" style="padding:.5rem 0">
            @{
                var topLbls = (string[])ViewBag.TopLabels; var topDatas = (int[])ViewBag.TopData;
            }
            @if (topLbls != null)
            {
                for (int i = 0; i < topLbls.Length; i++)
                {
                    <div style="display:flex;justify-content:space-between;align-items:center;padding:.6rem 1.25rem;border-bottom:1px solid #f1f5f9">
                        <span style="font-size:.85rem;color:#374151">@topLbls[i]</span>
                        <span style="font-size:.85rem;font-weight:700;color:#0ea5e9">@topDatas[i] đã bán</span>
                    </div>
                }
            }
        </div>
    </div>
    <div class="card">
        <div class="card-header"><h5>Hoạt động gần đây</h5></div>
        <div class="card-body" style="padding:.5rem 0">
            @{
                var recentOrders = (List<MilkStore.Models.Order>)ViewBag.RecentOrders;
            }
            @if (recentOrders != null)
            {
                foreach (var o in recentOrders.Take(4))
                {
                    <div style="padding:.6rem 1.25rem;border-bottom:1px solid #f1f5f9">
                        <div style="font-size:.83rem;font-weight:600;color:#374151">Đơn hàng mới</div>
                        <div style="font-size:.78rem;color:#94a3b8">#@o.Id • @o.OrderDate.ToString("dd/MM HH:mm")</div>
                    </div>
                }
            }
        </div>
    </div>
    <div class="card">
        <div class="card-header"><h5>Kho hàng cảnh báo</h5></div>
        <div class="card-body" style="padding:.5rem 0">
            @if (topLbls != null)
            {
                <div style="padding:.6rem 1.25rem;border-bottom:1px solid #f1f5f9;display:flex;justify-content:space-between;align-items:center">
                    <span style="font-size:.83rem">Sắp hết hàng</span>
                    <span class="badge badge-low" style="background:#fee2e2;color:#dc2626">Sắp hết</span>
                </div>
                <div style="padding:.6rem 1.25rem;border-bottom:1px solid #f1f5f9;display:flex;justify-content:space-between;align-items:center">
                    <span style="font-size:.83rem">Tồn kho thấp</span>
                    <span class="badge" style="background:#fef3c7;color:#d97706">Thấp</span>
                </div>
            }
            <div style="padding:1rem 1.25rem;font-size:.83rem;color:#94a3b8">
                <a asp-area="Admin" asp-controller="Product" asp-action="Index" style="color:#0ea5e9;font-weight:600;text-decoration:none">Xem tất cả sản phẩm →</a>
            </div>
        </div>
    </div>
</div>

<!-- Recent orders table -->
<div class="card">
    <div class="card-header">
        <h5>Đơn hàng gần nhất</h5>
        <a asp-area="Admin" asp-controller="Order" asp-action="Index" class="btn btn-primary btn-sm">Xem tất cả</a>
    </div>
    <table class="tbl">
        <thead>
            <tr><th>#</th><th>Khách hàng</th><th>Ngày đặt</th><th>Tổng tiền</th><th>Thanh toán</th><th>Trạng thái</th></tr>
        </thead>
        <tbody>
            @if (recentOrders != null)
            {
                foreach (var o in recentOrders)
                {
                    <tr>
                        <td><strong style="color:#0ea5e9">#@o.Id</strong></td>
                        <td>@o.User?.FullName</td>
                        <td style="color:#94a3b8;font-size:.82rem">@o.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                        <td style="font-weight:700;color:#0ea5e9">@String.Format("{0:N0}đ", o.TotalAmount)</td>
                        <td>@o.PaymentMethod</td>
                        <td>
                            @{
                                var bc = o.Status?.ToLower() == "paid" ? "badge-paid" :
                                         o.Status?.ToLower() == "cancelled" ? "badge-cancelled" : "badge-pending";
                            }
                            <span class="badge @bc">@o.Status</span>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script>
        const labels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.RevenueLabels));
        const data   = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.RevenueData));
        const topLbl = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.TopLabels));
        const topData= @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.TopData));

        Chart.defaults.font.family = 'Inter';
        Chart.defaults.color = '#64748b';

        const ctx1 = document.getElementById('revenueChart');
        new Chart(ctx1, {
            type: 'line',
            data: {
                labels,
                datasets: [{
                    label: 'Doanh thu',
                    data,
                    borderColor: '#0ea5e9',
                    backgroundColor: 'rgba(14,165,233,.08)',
                    tension: .4,
                    fill: true,
                    pointBackgroundColor: '#0ea5e9',
                    pointRadius: 4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    y: { grid: { color: '#f1f5f9' }, ticks: { callback: v => (v/1000000).toFixed(0)+'M' } },
                    x: { grid: { display: false } }
                }
            }
        });

        const ctx2 = document.getElementById('topChart');
        new Chart(ctx2, {
            type: 'bar',
            data: {
                labels: ['Đang đóng gói','Đang giao','Đã giao hàng','Đã hủy'],
                datasets: [{ data: [20,60,310,5], backgroundColor: ['#bfdbfe','#93c5fd','#10b981','#fca5a5'], borderRadius: 6 }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: { y: { grid: { color: '#f1f5f9' } }, x: { grid: { display: false } } }
            }
        });

        function switchChart(type){
            document.getElementById('btn-day').className = type==='day' ? 'btn btn-primary btn-sm' : 'btn btn-ghost btn-sm';
            document.getElementById('btn-month').className = type==='month' ? 'btn btn-primary btn-sm' : 'btn btn-ghost btn-sm';
        }
    </script>
}
