@{
    ViewData["Title"] = "Chat Dashboard";
    <link rel="icon" type="image/png" href="~/images/logo-transparent.png" />
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<style>
.chat-dash { display: flex; height: calc(100vh - 120px); gap: 0; border-radius: 12px; overflow: hidden; border: 1px solid #e0e6ea; }
.session-list { width: 280px; flex-shrink: 0; background: #fff; border-right: 1px solid #e0e6ea; display: flex; flex-direction: column; }
.session-list-hdr { padding: 14px 16px; font-weight: 700; font-size: 14px; border-bottom: 1px solid #e0e6ea; background: #f8f9fb; }
.session-item { padding: 12px 16px; cursor: pointer; border-bottom: 1px solid #f0f4f7; transition: background .15s; }
.session-item:hover, .session-item.active { background: #f0faf8; }
.session-id { font-size: 12px; font-weight: 700; color: #2d3436; }
.session-preview { font-size: 11px; color: #7f8c8d; margin-top: 2px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.session-meta { display: flex; justify-content: space-between; align-items: center; margin-top: 3px; }
.session-time { font-size: 10px; color: #b2bec3; }
.unread-badge { background: #e17055; color: #fff; border-radius: 10px; font-size: 10px; font-weight: 700; padding: 1px 7px; }

.chat-area { flex: 1; display: flex; flex-direction: column; background: #f4f6f8; }
.chat-area-hdr { padding: 12px 16px; background: #fff; border-bottom: 1px solid #e0e6ea; font-weight: 700; font-size: 14px; color: #2d3436; }
.chat-msgs { flex: 1; overflow-y: auto; padding: 12px; display: flex; flex-direction: column; gap: 8px; }
.msg-row { display: flex; align-items: flex-end; gap: 6px; }
.msg-row.me { flex-direction: row-reverse; }
.msg-row.bot-row { opacity: 0.85; }
.msg-av { width: 26px; height: 26px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 11px; color: #fff; font-weight: 700; flex-shrink: 0; }
.msg-av.user-av { background: #6c5ce7; }
.msg-av.bot-av { background: #00b894; }
.msg-av.admin-av { background: #e17055; }
.msg-bub { max-width: 70%; padding: 8px 12px; font-size: 13px; line-height: 1.55; border-radius: 4px 14px 14px 14px; }
.msg-bub.user { background: #fff; border: 1px solid #e0e6ea; color: #2d3436; }
.msg-bub.bot { background: #e8f8f4; border: 1px solid #b2f5ea; color: #2d3436; border-radius: 14px 4px 14px 14px; }
.msg-bub.admin { background: #e17055; color: #fff; border-radius: 14px 4px 14px 14px; }
.msg-time { font-size: 10px; color: #b2bec3; margin-top: 2px; }
.role-lbl { font-size: 10px; color: #b2bec3; margin-bottom: 2px; }

.admin-input { padding: 10px 14px; background: #fff; border-top: 1px solid #e0e6ea; display: flex; gap: 8px; }
.admin-input input { flex: 1; border: 1.5px solid #e0e6ea; border-radius: 20px; padding: 8px 14px; font-size: 13px; outline: none; }
.admin-input input:focus { border-color: #00b894; }
.admin-send-btn { background: #00b894; color: #fff; border: none; border-radius: 20px; padding: 8px 18px; font-size: 13px; cursor: pointer; font-weight: 600; }
.admin-send-btn:hover { background: #00997a; }
.no-session { flex: 1; display: flex; align-items: center; justify-content: center; color: #b2bec3; font-size: 14px; }
.new-msg-dot { width: 8px; height: 8px; border-radius: 50%; background: #e17055; display: inline-block; margin-left: 6px; animation: pulse 1.5s infinite; }
@@keyframes pulse { 0%,100%{opacity:1} 50%{opacity:.3} }
</style>

<div class="chat-dash">
    <div class="session-list">
        <div class="session-list-hdr">💬 Hội thoại <span id="session-count" style="color:#b2bec3;font-weight:400"></span></div>
        <div id="session-items" style="overflow-y:auto;flex:1"></div>
    </div>

    <div class="chat-area">
        <div class="chat-area-hdr" id="chat-hdr">Chọn một hội thoại để xem</div>
        <div class="chat-msgs" id="chat-msgs">
            <div class="no-session">Chưa có hội thoại nào được chọn</div>
        </div>
        <div class="admin-input" id="admin-input" style="display:none">
            <input id="admin-msg" placeholder="Nhập tin nhắn trả lời khách..." onkeydown="if(event.key==='Enter')adminSend()"/>
            <button class="admin-send-btn" onclick="adminSend()">Gửi</button>
        </div>
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
<script>
let currentSession = null;
const sessions = {};

const conn = new signalR.HubConnectionBuilder()
    .withUrl("/chatHub")
    .withAutomaticReconnect()
    .build();

conn.on("ReceiveMessage", (msg) => {
    if (!sessions[msg.sessionId]) sessions[msg.sessionId] = [];
    sessions[msg.sessionId].push(msg);

    if (msg.sessionId === currentSession) {
        appendMsg(msg);
    } else if (msg.role === "user") {
        markUnread(msg.sessionId);
    }
    refreshSessionList(msg);
});

conn.start().then(() => {
    conn.invoke("JoinAdmin");
    loadSessions();
});

async function loadSessions() {
    const res = await fetch('/Chat/Sessions');
    const data = await res.json();
    document.getElementById('session-count').textContent = `(${data.length})`;
    data.forEach(s => {
        if (!sessions[s.sessionId]) sessions[s.sessionId] = [];
        renderSessionItem(s);
    });
}

function renderSessionItem(s) {
    let el = document.getElementById('si_' + s.sessionId);
    if (!el) {
        el = document.createElement('div');
        el.className = 'session-item';
        el.id = 'si_' + s.sessionId;
        el.onclick = () => openSession(s.sessionId);
        document.getElementById('session-items').prepend(el);
    }
    const unread = s.unread > 0 ? `<span class="unread-badge">${s.unread}</span>` : '';
    const time = s.lastTime ? new Date(s.lastTime).toLocaleTimeString('vi-VN', {hour:'2-digit',minute:'2-digit'}) : '';
    el.innerHTML = `
        <div class="session-id">${s.sessionId.slice(0,12)}...</div>
        <div class="session-preview">${s.lastMessage || ''}</div>
        <div class="session-meta"><span class="session-time">${time}</span>${unread}</div>`;
}

function refreshSessionList(msg) {
    const existing = document.getElementById('si_' + msg.sessionId);
    const unread = msg.role === 'user' && msg.sessionId !== currentSession ? 1 : 0;
    renderSessionItem({ sessionId: msg.sessionId, lastMessage: msg.content, lastTime: new Date().toISOString(), unread });
}

function markUnread(sessionId) {
    const el = document.getElementById('si_' + sessionId);
    if (el && !el.querySelector('.new-msg-dot')) {
        el.querySelector('.session-id').insertAdjacentHTML('beforeend', '<span class="new-msg-dot"></span>');
    }
}

async function openSession(sessionId) {
    currentSession = sessionId;
    document.querySelectorAll('.session-item').forEach(e => e.classList.remove('active'));
    const el = document.getElementById('si_' + sessionId);
    if (el) {
        el.classList.add('active');
        el.querySelector('.new-msg-dot')?.remove();
        el.querySelector('.unread-badge')?.remove();
    }

    document.getElementById('chat-hdr').textContent = '🗨️ Session: ' + sessionId;
    document.getElementById('admin-input').style.display = 'flex';

    const msgsEl = document.getElementById('chat-msgs');
    msgsEl.innerHTML = '';

    if (!sessions[sessionId] || sessions[sessionId].length === 0) {
        const res = await fetch('/Chat/History?sessionId=' + sessionId);
        const data = await res.json();
        sessions[sessionId] = data;
    }
    sessions[sessionId].forEach(appendMsg);
}

function appendMsg(msg) {
    const msgsEl = document.getElementById('chat-msgs');
    const row = document.createElement('div');
    row.className = `msg-row${msg.role === 'user' ? '' : ' me'}${msg.role === 'bot' ? ' bot-row' : ''}`;

    const avClass = msg.role === 'user' ? 'user-av' : msg.role === 'bot' ? 'bot-av' : 'admin-av';
    const avText  = msg.role === 'user' ? 'K' : msg.role === 'bot' ? 'AI' : 'AD';

    row.innerHTML = `
        <div class="msg-av ${avClass}">${avText}</div>
        <div>
            <div class="role-lbl">${msg.role === 'user' ? 'Khách' : msg.role === 'bot' ? 'Mai (AI)' : 'Admin'}</div>
            <div class="msg-bub ${msg.role}">${msg.content}</div>
            <div class="msg-time">${msg.createdAt || ''}</div>
        </div>`;
    msgsEl.appendChild(row);
    msgsEl.scrollTop = msgsEl.scrollHeight;
}

function adminSend() {
    const inp = document.getElementById('admin-msg');
    const msg = inp.value.trim();
    if (!msg || !currentSession) return;
    inp.value = '';
    conn.invoke("SendAdminMessage", currentSession, msg);
}
</script>
