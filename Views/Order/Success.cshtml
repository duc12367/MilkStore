@model MilkStore.Models.Order
@{
    ViewData["Title"] = "Đặt hàng thành công";
    <link rel="icon" type="image/png" href="~/images/logo-transparent.png" />
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5" style="max-width:560px; text-align:center">
    <div class="success-card">
        <div class="success-icon">✓</div>
        <h2>Đặt hàng thành công!</h2>
        <p>Mã đơn hàng: <strong>#@Model.Id</strong></p>
        <p>Phương thức: <strong>@Model.PaymentMethod</strong></p>
        <p>Địa chỉ giao: @Model.ShippingAddress</p>

        <div class="success-total">
            Tổng tiền:
            <strong>@String.Format("{0:N0}đ", Model.TotalAmount)</strong>
        </div>

        <div class="success-actions">
            <a asp-controller="Order" asp-action="MyOrders" class="btn-orders">
                 Xem đơn hàng
            </a>
            <a asp-controller="Home" asp-action="Index" class="btn-home">
                Tiếp tục mua sắm
            </a>
        </div>
    </div>
</div>

<style>
.success-card {
    background: #fff; border-radius: 16px;
    padding: 2.5rem; box-shadow: 0 8px 32px rgba(0,0,0,0.10);
}
.success-icon {
    width: 72px; height: 72px;
    background: linear-gradient(135deg,#8e24aa,#e91e8c);
    border-radius: 50%; color: #fff;
    font-size: 2rem; font-weight: 700;
    display: flex; align-items: center;
    justify-content: center; margin: 0 auto 1.25rem;
}
.success-card h2 { font-size: 1.5rem; margin-bottom: .75rem; }
.success-card p  { color: #555; margin-bottom: .4rem; }
.success-total {
    font-size: 1.2rem; margin: 1.25rem 0;
    padding: 1rem; background: #faf5ff; border-radius: 10px;
}
.success-total strong { color: #e91e8c; font-size: 1.4rem; }
.success-actions {
    display: flex; gap: 1rem; justify-content: center; margin-top: 1.25rem;
}
.btn-orders {
    background: #8e24aa; color: #fff; border-radius: 10px;
    padding: .65rem 1.5rem; font-weight: 700;
    text-decoration: none;
}
.btn-home {
    background: #f3e5f5; color: #6a1b9a; border-radius: 10px;
    padding: .65rem 1.5rem; font-weight: 700;
    text-decoration: none;
}
</style>

