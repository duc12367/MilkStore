@{
    ViewData["Title"] = "Đặt hàng";
    <link rel="icon" type="image/png" href="~/images/logo-transparent.png" />
    Layout = "~/Views/Shared/_Layout.cshtml";
    var items = (List<MilkStore.Models.CartItem>)ViewBag.Items;
}

<div class="container mt-4" style="max-width:800px">
    <h2 class="mb-4"> Xác nhận đặt hàng</h2>

    <div class="checkout-grid">
        <!-- Form -->
        <div class="checkout-form-wrap">
            <form asp-action="PlaceOrder" method="post">
                @Html.AntiForgeryToken()

                <div class="form-section">
                    <h5>Thông tin giao hàng</h5>
                    <div class="form-group">
                        <label>Số điện thoại <span style="color:red">*</span></label>
                        <input type="tel" name="phone"
                               value="@ViewBag.DefaultPhone"
                               class="form-control" required
                               placeholder="Nhập số điện thoại liên hệ"
                               pattern="[0-9]{10,11}"
                               title="Vui lòng nhập số điện thoại" />
                        <span class="field-validation" data-valmsg-for="phone">Vui lòng nhập số điện thoại</span>
                    </div>
                    <div class="form-group">
                        <label>Email liên hệ</label>
                        <input type="email" name="email"
                               value="@ViewBag.DefaultEmail"
                               class="form-control"
                               placeholder="abc@gmail.com"
                               title="Email không đúng định dạng" />
                        <span class="field-validation" data-valmsg-for="email">Email không đúng định dạng</span>
                    </div>
                    <div class="form-group">
                        <label>Địa chỉ nhận hàng</label>
                        <input type="text" name="shippingAddress"
                               value="@ViewBag.DefaultAddress"
                               class="form-control" required
                               placeholder="Số nhà, đường, quận, thành phố" />
                    </div>
                    <div class="form-group">
                        <label>Ghi chú</label>
                        <textarea name="note" class="form-control"
                                  placeholder="Ghi chú cho shipper..."
                                  rows="2"></textarea>
                    </div>
                </div>

                <div class="form-section">
                    <h5>Phương thức thanh toán</h5>
                    <div class="payment-options">
                        <label class="payment-opt">
                            <input type="radio" name="paymentMethod"
                                   value="COD" checked />
                            <span> Thanh toán khi nhận hàng (COD)</span>
                        </label>
                        <label class="payment-opt">
                            <input type="radio" name="paymentMethod"
                                   value="MoMo" />
                            <span> Ví MOMO</span>
                        </label>
                    </div>
                </div>

                @if (TempData["Error"] != null)
                {
                    <div class="alert-error">@TempData["Error"]</div>
                }

                <div class="form-section">
                    <h5> Mã giảm giá</h5>
                    <div class="coupon-row">
                        <input type="text" name="couponCode" class="form-control"
                               placeholder="Nhập mã giảm giá (VD: SALE10)"
                               style="text-transform:uppercase" />
                        <small style="color:#888;margin-top:.3rem;display:block">Mã không phân biệt chữ hoa/thường</small>
                    </div>
                </div>

                <button type="submit" class="btn-place-order">
                    Đặt hàng ngay
                </button>
            </form>
        </div>

        <!-- Tóm tắt đơn -->
        <div class="order-summary">
            <h5>Tóm tắt đơn hàng</h5>
            @foreach (var item in items)
            {
                <div class="summary-row">
                    <img src="@(item.Product?.ImageUrl ?? "https://placehold.co/50x50")"
                         class="summary-img" />
                    <div class="summary-name">
                        <span>@(item.Product?.ProductName ?? "")</span>
                        <small>x@item.Quantity</small>
                    </div>
                    <span class="summary-price">
                        @String.Format("{0:N0}đ",
                            (item.Product?.Price ?? 0m) * item.Quantity)
                    </span>
                </div>
            }
            <div class="summary-total">
                <span>Tổng cộng</span>
                <strong>@String.Format("{0:N0}đ", ViewBag.Total)</strong>
            </div>
        </div>
    </div>
</div>

<style>
    .field-validation {
        display: none; font-size: .8rem; color: #d32f2f; margin-top: .25rem;
    }
    input:invalid:not(:placeholder-shown) + .field-validation { display: block; }
    .coupon-row { display: flex; flex-direction: column; }
    .alert-error {
        background: #fdecea; color: #c62828; border: 1px solid #f5c6cb;
        border-radius: 8px; padding: .75rem 1rem; margin-bottom: 1rem; font-size: .9rem;
    }
    .checkout-grid {
        display: grid; grid-template-columns: 1.2fr 1fr; gap: 2rem;
    }
    .form-section {
        background: #fff; border-radius: 12px;
        padding: 1.25rem; margin-bottom: 1rem;
        box-shadow: 0 2px 8px rgba(0,0,0,0.06);
    }
    .form-section h5 { font-weight: 700; margin-bottom: 1rem; color: #333; }
    .form-group { margin-bottom: .9rem; }
    .form-group label {
        display: block; font-size: .875rem;
        font-weight: 500; color: #555; margin-bottom: .3rem;
    }
    .form-control {
        width: 100%; padding: .6rem .9rem;
        border: 1.5px solid #e0e0e0; border-radius: 8px;
        font-size: .95rem; box-sizing: border-box;
    }
    .payment-options { display: flex; flex-direction: column; gap: .6rem; }
    .payment-opt {
        display: flex; align-items: center; gap: .75rem;
        padding: .75rem 1rem; border: 1.5px solid #e0e0e0;
        border-radius: 8px; cursor: pointer; transition: border-color .2s;
    }
    .payment-opt:has(input:checked) { border-color: #8e24aa; background: #faf5ff; }
    .btn-place-order {
        width: 100%; padding: .85rem;
        background: linear-gradient(90deg,#8e24aa,#e91e8c);
        color: #fff; border: none; border-radius: 10px;
        font-size: 1rem; font-weight: 700; cursor: pointer;
    }
    .order-summary {
        background: #fff; border-radius: 12px; padding: 1.25rem;
        box-shadow: 0 2px 8px rgba(0,0,0,0.06); height: fit-content;
    }
    .order-summary h5 { font-weight: 700; margin-bottom: 1rem; }
    .summary-row {
        display: flex; align-items: center; gap: .75rem;
        margin-bottom: .75rem;
    }
    .summary-img {
        width: 46px; height: 46px; object-fit: cover;
        border-radius: 6px; flex-shrink: 0;
    }
    .summary-name { flex: 1; font-size: .88rem; }
    .summary-name small { display: block; color: #999; }
    .summary-price { font-weight: 700; color: #e91e8c; font-size: .9rem; }
    .summary-total {
        display: flex; justify-content: space-between;
        border-top: 2px solid #f3e5f5; padding-top: .85rem;
        margin-top: .5rem; font-size: 1rem;
    }
    .summary-total strong { font-size: 1.2rem; color: #e91e8c; }
    @@media(max-width:640px) { .checkout-grid { grid-template-columns: 1fr; } }
</style>
