@model MilkStore.Models.Order
@{
    ViewData["Title"] = $"Chi tiết đơn #{Model.Id}";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4" style="max-width:720px">
    <div class="od-card">
        <div class="od-header">
            <div>
                <h4 style="margin:0"> Đơn hàng #@Model.Id</h4>
                <span style="font-size:.85rem;color:#888">@Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</span>
            </div>
            <span class="status-badge status-@Model.Status.ToLower()">@Model.Status</span>
        </div>

        <div class="od-info">
            <div class="info-block">
                <div class="info-label">Địa chỉ giao hàng</div>
                <div>@Model.ShippingAddress</div>
            </div>
            <div class="info-block">
                <div class="info-label">Phương thức thanh toán</div>
                <div>@Model.PaymentMethod</div>
            </div>
            @if (!string.IsNullOrEmpty(Model.Note))
            {
                <div class="info-block">
                    <div class="info-label">Ghi chú</div>
                    <div>@Model.Note</div>
                </div>
            }
        </div>

        <table class="od-table">
            <thead><tr><th>Sản phẩm</th><th>Đơn giá</th><th>SL</th><th>Thành tiền</th></tr></thead>
            <tbody>
                @foreach (var item in Model.OrderItems)
                {
                    <tr>
                        <td>
                            <div style="display:flex;align-items:center;gap:.75rem">
                                <img src="@(item.Product?.ImageUrl ?? "https://placehold.co/50x50")"
                                     style="width:48px;height:48px;object-fit:cover;border-radius:6px" />
                                <span style="font-weight:600">@item.Product?.ProductName</span>
                            </div>
                        </td>
                        <td>@String.Format("{0:N0}đ", item.PriceAtTime)</td>
                        <td>x@item.Quantity</td>
                        <td style="font-weight:700;color:#e91e8c">
                            @String.Format("{0:N0}đ", item.PriceAtTime * item.Quantity)
                        </td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr>
                    <td colspan="3" style="text-align:right;font-weight:700;padding:.85rem 1rem">Tổng cộng</td>
                    <td style="font-weight:800;color:#e91e8c;font-size:1.15rem;padding:.85rem 1rem">
                        @String.Format("{0:N0}đ", Model.TotalAmount)
                    </td>
                </tr>
            </tfoot>
        </table>

        <div style="padding:1.25rem;display:flex;gap:1rem">
            <a asp-action="MyOrders" style="background:#f3e5f5;color:#6a1b9a;border-radius:8px;padding:.6rem 1.25rem;font-weight:600;text-decoration:none">← Đơn hàng của tôi</a>
            <a asp-controller="Home" asp-action="Index" style="background:#8e24aa;color:#fff;border-radius:8px;padding:.6rem 1.25rem;font-weight:600;text-decoration:none">Tiếp tục mua sắm</a>
        </div>
    </div>
</div>

<style>
.od-card { background:#fff;border-radius:14px;box-shadow:0 4px 20px rgba(0,0,0,.08);overflow:hidden; }
.od-header { display:flex;justify-content:space-between;align-items:center;padding:1.25rem 1.5rem;border-bottom:1px solid #f0f0f0; }
.status-badge { padding:.3rem .85rem;border-radius:20px;font-size:.8rem;font-weight:700; }
.status-paid      { background:#e8f5e9;color:#2e7d32; }
.status-pending   { background:#fff8e1;color:#f57f17; }
.status-cancelled { background:#fce4ec;color:#c62828; }
.od-info { display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;padding:1.25rem 1.5rem;background:#faf5ff;border-bottom:1px solid #f0f0f0; }
.info-label { font-size:.78rem;color:#999;font-weight:600;text-transform:uppercase;letter-spacing:.5px;margin-bottom:.25rem; }
.od-table { width:100%;border-collapse:collapse;font-size:.9rem; }
.od-table th { background:#faf5ff;padding:.75rem 1rem;text-align:left;font-weight:600;color:#555;font-size:.82rem;text-transform:uppercase; }
.od-table td { padding:.85rem 1rem;border-top:1px solid #f5f5f5;vertical-align:middle; }
</style>
