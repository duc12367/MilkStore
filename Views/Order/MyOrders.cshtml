@model List<MilkStore.Models.Order>
@{
    ViewData["Title"] = "Đơn hàng của tôi";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
.orders-wrap{max-width:960px;margin:0 auto;padding:2rem 1rem}
.orders-header{display:flex;align-items:center;gap:.75rem;margin-bottom:1.5rem}
.orders-header h2{font-size:1.4rem;font-weight:700;color:#0f172a;margin:0}
.order-count{background:#f0f9ff;color:#0ea5e9;border-radius:20px;padding:.2rem .75rem;font-size:.8rem;font-weight:700}
.orders-layout{display:grid;grid-template-columns:1fr 360px;gap:1.25rem;align-items:start}
.order-card{
    background:#fff;border-radius:14px;border:1px solid #e2e8f0;
    margin-bottom:.875rem;overflow:hidden;cursor:pointer;
    transition:border-color .2s,box-shadow .2s;
}
.order-card:hover,.order-card.selected{border-color:#0ea5e9;box-shadow:0 0 0 3px rgba(14,165,233,.1)}
.order-card-hdr{
    padding:.875rem 1.25rem;
    display:flex;justify-content:space-between;align-items:center;
    border-bottom:1px solid #f1f5f9;
}
.order-id{font-weight:700;font-size:.92rem;color:#0f172a}
.order-date{font-size:.78rem;color:#94a3b8;margin-top:.15rem}
.order-items-row{padding:.75rem 1.25rem;display:flex;gap:.75rem;align-items:center}
.order-item-img{
    width:48px;height:48px;object-fit:cover;border-radius:8px;
    border:1px solid #e2e8f0;flex-shrink:0;cursor:pointer;
    transition:transform .2s;
}
.order-item-img:hover{transform:scale(1.08)}
.order-item-info{flex:1;min-width:0}
.order-item-name{font-size:.85rem;font-weight:600;color:#374151;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.order-item-qty{font-size:.78rem;color:#94a3b8;margin-top:.1rem}
.order-item-price{font-size:.88rem;font-weight:700;color:#0f172a;flex-shrink:0}
.order-addr{
    padding:.5rem 1.25rem;font-size:.8rem;color:#94a3b8;
    display:flex;align-items:center;gap:.4rem;
}
.order-footer{
    padding:.75rem 1.25rem;border-top:1px solid #f1f5f9;
    display:flex;justify-content:space-between;align-items:center;
}
.order-total-label{font-size:.82rem;color:#94a3b8}
.order-total-val{font-size:1rem;font-weight:700;color:#0ea5e9}

.status-badge{display:inline-flex;align-items:center;gap:.3rem;padding:.3rem .8rem;border-radius:20px;font-size:.75rem;font-weight:700}
.status-pending{background:#fef9c3;color:#854d0e}
.status-paid{background:#dcfce7;color:#166534}
.status-cancelled{background:#fee2e2;color:#991b1b}
.status-shipping{background:#dbeafe;color:#1e40af}

.detail-panel{
    background:#fff;border-radius:14px;border:1px solid #e2e8f0;
    position:sticky;top:80px;overflow:hidden;
}
.detail-panel-empty{
    padding:3rem 1.5rem;text-align:center;color:#94a3b8;
}
.detail-panel-empty svg{width:48px;height:48px;margin-bottom:.75rem;opacity:.3}
.detail-panel-content{display:none;padding:1.25rem}
.detail-panel-content.active{display:block}

.empty-wrap{text-align:center;padding:5rem 2rem;color:#94a3b8}
.empty-wrap svg{width:64px;height:64px;opacity:.2;margin-bottom:1rem}
.empty-wrap h3{font-size:1.1rem;font-weight:600;color:#374151;margin-bottom:.5rem}
.empty-wrap p{font-size:.88rem;margin-bottom:1.5rem}

/* cancel button */
.btn-cancel-order{
    background:#fee2e2;color:#991b1b;border:none;border-radius:8px;
    padding:.4rem .9rem;font-size:.8rem;font-weight:600;cursor:pointer;
    display:inline-flex;align-items:center;gap:.35rem;transition:background .2s;
}
.btn-cancel-order:hover{background:#fecaca}

@@media(max-width:768px){
    .orders-layout{grid-template-columns:1fr}
    .detail-panel{display:none}
}
</style>

<div class="orders-wrap">
    <div class="orders-header">
        <div style="width:36px;height:36px;border-radius:10px;background:linear-gradient(135deg,#0ea5e9,#06b6d4);display:flex;align-items:center;justify-content:center">
            <svg viewBox="0 0 20 20" fill="white" style="width:18px;height:18px"><path d="M9 2a1 1 0 000 2h2a1 1 0 100-2H9z"/><path fill-rule="evenodd" d="M4 5a2 2 0 012-2 3 3 0 003 3h2a3 3 0 003-3 2 2 0 012 2v11a2 2 0 01-2 2H6a2 2 0 01-2-2V5zm3 4a1 1 0 000 2h.01a1 1 0 100-2H7zm3 0a1 1 0 000 2h3a1 1 0 100-2h-3zm-3 4a1 1 0 100 2h.01a1 1 0 100-2H7zm3 0a1 1 0 100 2h3a1 1 0 100-2h-3z" clip-rule="evenodd"/></svg>
        </div>
        <div>
            <h2>Đơn hàng của tôi</h2>
            <div style="font-size:.82rem;color:#94a3b8">Quản lý đơn hàng của bạn</div>
        </div>
        @if (Model.Any())
        {
            <span class="order-count">@Model.Count đơn hàng</span>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="empty-wrap">
            <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1"><path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
            <h3>Chưa có đơn hàng nào</h3>
            <p>Hãy khám phá các sản phẩm sữa chất lượng của chúng mình!</p>
            <a asp-controller="Product" asp-action="Index"
               style="background:#0ea5e9;color:#fff;padding:.75rem 2rem;border-radius:10px;font-weight:700;text-decoration:none;display:inline-block">
                Mua sắm ngay
            </a>
        </div>
    }
    else
    {
        <div class="orders-layout">
            <div id="order-list">
                @foreach (var order in Model)
                {
                    var statusCls = order.Status?.ToLower() == "paid" ? "status-paid" :
                                    order.Status?.ToLower() == "cancelled" ? "status-cancelled" :
                                    order.Status?.ToLower() == "shipping" ? "status-shipping" : "status-pending";
                    var statusLbl = order.Status?.ToLower() == "paid" ? "Đã giao hàng" :
                                    order.Status?.ToLower() == "cancelled" ? "Đã hủy" :
                                    order.Status?.ToLower() == "shipping" ? "Đang giao hàng" : "Đang đóng gói";
                    <div class="order-card" onclick="selectOrder(@(order.Id))" id="oc_@(order.Id)">
                        <div class="order-card-hdr">
                            <div>
                                <div class="order-id">Đơn hàng #MS@(order.Id.ToString("D11"))</div>
                                <div class="order-date">
                                    <svg viewBox="0 0 20 20" fill="currentColor" style="width:11px;height:11px;display:inline;vertical-align:middle;margin-right:3px"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"/></svg>
                                    @order.OrderDate.ToString("dd/MM/yyyy HH:mm")
                                </div>
                            </div>
                            <span class="status-badge @statusCls">@statusLbl</span>
                        </div>

                        @foreach (var item in order.OrderItems.Take(2))
                        {
                            <div class="order-items-row">
                                {{!-- ✅ FIX 3: Ảnh sản phẩm có thể click để xem chi tiết sản phẩm --}}
                                <a asp-controller="Product" asp-action="Detail" asp-route-id="@(item.ProductId)"
                                   onclick="event.stopPropagation()">
                                    <img src="@(item.Product?.ImageUrl ?? "https://placehold.co/48x48/f0f4f8/94a3b8?text=SP")"
                                         class="order-item-img"
                                         title="@item.Product?.ProductName"
                                         onerror="this.src='https://placehold.co/48x48/f0f4f8/94a3b8?text=SP'"/>
                                </a>
                                <div class="order-item-info">
                                    <div class="order-item-name">@item.Product?.ProductName</div>
                                    <div class="order-item-qty">Số lượng: @item.Quantity</div>
                                </div>
                                <div class="order-item-price">@String.Format("{0:N0}đ", item.PriceAtTime * item.Quantity)</div>
                            </div>
                        }
                        @if (order.OrderItems.Count > 2)
                        {
                            <div style="padding:.3rem 1.25rem;font-size:.78rem;color:#94a3b8">+@(order.OrderItems.Count-2) sản phẩm khác</div>
                        }

                        <div class="order-addr">
                            <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" style="width:13px;height:13px;flex-shrink:0"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                            @order.ShippingAddress
                        </div>

                        @if (order.Status?.ToLower() == "shipping")
                        {
                            <div style="margin:.5rem 1.25rem;padding:.5rem .875rem;background:#eff6ff;border-radius:8px;font-size:.78rem;color:#1d4ed8;display:flex;align-items:center;gap:.4rem">
                                <svg viewBox="0 0 20 20" fill="currentColor" style="width:13px;height:13px"><path d="M8 16.5a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0zM15 16.5a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0z"/><path d="M3 4a1 1 0 00-1 1v10a1 1 0 001 1h1.05a2.5 2.5 0 014.9 0H10a1 1 0 001-1V5a1 1 0 00-1-1H3zM14 7a1 1 0 00-1 1v6.05A2.5 2.5 0 0115.95 16H17a1 1 0 001-1v-5a1 1 0 00-.293-.707l-2-2A1 1 0 0015 7h-1z"/></svg>
                                Dự kiến giao: @order.OrderDate.AddDays(1).ToString("dd/MM/yyyy")
                            </div>
                        }

                        <div class="order-footer">
                            <div>
                                <div class="order-total-label">Tổng cộng:</div>
                                <div class="order-total-val">@String.Format("{0:N0}đ", order.TotalAmount)</div>
                            </div>
                            <div style="display:flex;gap:.5rem;align-items:center" onclick="event.stopPropagation()">
                                @if (order.Status?.ToLower() == "pending")
                                {
                                    <form asp-controller="Order" asp-action="CancelOrder" method="post"
                                          onsubmit="return confirm('Bạn có chắc muốn hủy đơn hàng này?')">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@(order.Id)" />
                                        <button type="submit" class="btn-cancel-order">
                                            <svg viewBox="0 0 20 20" fill="currentColor" style="width:12px;height:12px"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
                                            Hủy đơn
                                        </button>
                                    </form>
                                }
                                <a asp-action="Detail" asp-route-id="@(order.Id)"
                                   style="background:#f0f9ff;color:#0ea5e9;padding:.45rem 1rem;border-radius:8px;font-size:.82rem;font-weight:600;text-decoration:none">
                                    Xem chi tiết →
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <div class="detail-panel" id="detail-panel">
                <div class="detail-panel-empty" id="detail-empty">
                    <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1"><path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
                    <div style="font-weight:600;color:#374151;margin-bottom:.4rem">Chọn đơn hàng</div>
                    <div style="font-size:.83rem">Nhấn vào đơn hàng để xem chi tiết theo dõi</div>
                </div>

                @foreach (var order in Model)
                {
                    var statusCls2 = order.Status?.ToLower() == "paid" ? "status-paid" :
                                     order.Status?.ToLower() == "cancelled" ? "status-cancelled" :
                                     order.Status?.ToLower() == "shipping" ? "status-shipping" : "status-pending";
                    var statusLbl2 = order.Status?.ToLower() == "paid" ? "Đã giao hàng" :
                                     order.Status?.ToLower() == "cancelled" ? "Đã hủy" :
                                     order.Status?.ToLower() == "shipping" ? "Đang giao hàng" : "Đang đóng gói";
                    <div class="detail-panel-content" id="dp_@(order.Id)">
                        <div style="font-weight:700;font-size:.95rem;color:#0f172a;margin-bottom:.75rem;padding-bottom:.75rem;border-bottom:1px solid #f1f5f9">
                            Đơn hàng #MS@(order.Id.ToString("D11"))
                        </div>
                        <div style="display:flex;justify-content:space-between;margin-bottom:.5rem">
                            <span style="font-size:.82rem;color:#94a3b8">Trạng thái</span>
                            <span class="status-badge @statusCls2">@statusLbl2</span>
                        </div>
                        <div style="display:flex;justify-content:space-between;margin-bottom:.5rem">
                            <span style="font-size:.82rem;color:#94a3b8">Ngày đặt</span>
                            <span style="font-size:.82rem;font-weight:600">@order.OrderDate.ToString("dd/MM/yyyy HH:mm")</span>
                        </div>
                        <div style="display:flex;justify-content:space-between;margin-bottom:.5rem">
                            <span style="font-size:.82rem;color:#94a3b8">Địa chỉ</span>
                            <span style="font-size:.82rem;font-weight:600;max-width:180px;text-align:right">@order.ShippingAddress</span>
                        </div>
                        <div style="margin:.85rem 0;border-top:1px dashed #e2e8f0;padding-top:.85rem">
                            <div style="font-size:.78rem;color:#94a3b8;font-weight:600;margin-bottom:.6rem">SẢN PHẨM</div>
                            @foreach (var item in order.OrderItems)
                            {
                                <div style="display:flex;align-items:center;gap:.6rem;margin-bottom:.6rem">
                                    <a asp-controller="Product" asp-action="Detail" asp-route-id="@(item.ProductId)">
                                        <img src="@(item.Product?.ImageUrl ?? "https://placehold.co/40x40/f0f4f8/94a3b8?text=SP")"
                                             style="width:40px;height:40px;object-fit:cover;border-radius:6px;border:1px solid #e2e8f0;cursor:pointer"
                                             onerror="this.src='https://placehold.co/40x40/f0f4f8/94a3b8?text=SP'"
                                             title="Xem sản phẩm"/>
                                    </a>
                                    <div style="flex:1;min-width:0">
                                        <div style="font-size:.82rem;font-weight:600;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">@item.Product?.ProductName</div>
                                        <div style="font-size:.75rem;color:#94a3b8">x@(item.Quantity)</div>
                                    </div>
                                    <div style="font-size:.82rem;font-weight:700">@String.Format("{0:N0}đ", item.PriceAtTime * item.Quantity)</div>
                                </div>
                            }
                        </div>
                        <div style="display:flex;justify-content:space-between;padding-top:.75rem;border-top:1px solid #f1f5f9">
                            <span style="font-weight:700">Tổng cộng</span>
                            <span style="font-weight:800;color:#0ea5e9">@String.Format("{0:N0}đ", order.TotalAmount)</span>
                        </div>
                        <a asp-action="Detail" asp-route-id="@(order.Id)"
                           style="display:block;text-align:center;margin-top:1rem;background:#0ea5e9;color:#fff;padding:.6rem;border-radius:10px;font-weight:700;text-decoration:none;font-size:.88rem">
                            Xem chi tiết đầy đủ →
                        </a>
                    </div>
                }
            </div>
        </div>
    }
</div>

<script>
function selectOrder(id) {
    // Highlight card
    document.querySelectorAll('.order-card').forEach(c => c.classList.remove('selected'));
    document.getElementById('oc_' + id)?.classList.add('selected');

    // ✅ FIX: Hiện nội dung chi tiết đúng đơn, ẩn placeholder
    document.getElementById('detail-empty').style.display = 'none';
    document.querySelectorAll('.detail-panel-content').forEach(p => p.classList.remove('active'));
    var panel = document.getElementById('dp_' + id);
    if (panel) panel.classList.add('active');
}
</script>
