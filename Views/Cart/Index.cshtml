@model List<MilkStore.Models.CartItem>
@{
    ViewData["Title"] = "Giỏ hàng";
    <link rel="icon" type="image/png" href="~/images/logo-transparent.png" />
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4" style="max-width:860px">
    <div class="page-hero"><div class="container"><h1 class="page-hero-title" style="font-size:1.6rem">Giỏ hàng của bạn</h1></div></div>

    @if (TempData["Success"] != null)
    {
        <div class="toast-success">@TempData["Success"]</div>
    }

    @if (!Model.Any())
    {
        <div class="empty-cart">
            <img src="https://cdn-icons-png.flaticon.com/512/3144/3144456.png" alt="" style="width:64px;height:64px;opacity:.3;display:block;margin:0 auto .75rem">
            <p>Giỏ hàng trống!</p>
            <a asp-controller="Product" asp-action="Index" class="btn-shop">
                Mua sắm ngay
            </a>
        </div>
    }
    else
    {
        <div class="cart-table">
            @foreach (var item in Model)
            {
                <div class="cart-row">
                    <img src="@(item.Product.ImageUrl ?? "https://placehold.co/80x80")"
                         class="cart-img" alt="@item.Product.ProductName" />
                    <div class="cart-name">
                        <a asp-controller="Product" asp-action="Detail"
                           asp-route-id="@item.ProductId">
                            @item.Product.ProductName
                        </a>
                        <span class="cart-unit">
                            @String.Format("{0:N0}đ", item.Product.Price) / cái
                        </span>
                    </div>

                    <form asp-controller="Cart" asp-action="Update"
                          method="post" class="qty-form">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="cartItemId" value="@item.Id" />
                        <input type="number" name="quantity" value="@item.Quantity"
                               min="1" max="99" class="cart-qty"
                               onchange="this.form.submit()" />
                    </form>

                    <div class="cart-subtotal">
                        @String.Format("{0:N0}đ",
                            item.Product.Price * item.Quantity)
                    </div>

                    <form asp-controller="Cart" asp-action="Remove" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="cartItemId" value="@item.Id" />
                        <button type="submit" class="btn-remove">✕</button>
                    </form>
                </div>
            }
        </div>

        <div class="cart-footer">
            <form asp-controller="Cart" asp-action="Clear" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn-clear"
                        onclick="return confirm('Xóa toàn bộ giỏ hàng?')">
                    <img src="https://cdn-icons-png.flaticon.com/512/3405/3405244.png" alt="" style="width:15px;height:15px;vertical-align:middle;margin-right:5px"> Xóa tất cả
                </button>
            </form>

            <div class="cart-total-area">
                <div class="cart-total">
                    Tổng cộng:
                    <strong>@String.Format("{0:N0}đ", ViewBag.Total)</strong>
                </div>
                <a asp-controller="Order" asp-action="Checkout"
                   class="btn-checkout">
                    Đặt hàng                
                </a>
            </div>
        </div>
    }
</div>

<style>
.empty-cart {
    text-align: center; padding: 4rem 0; color: #aaa;
}
.btn-shop {
    display: inline-block; background: #8e24aa; color: #fff;
    padding: .75rem 2rem; border-radius: 10px;
    font-weight: 700; text-decoration: none; margin-top: 1rem;
}
.cart-table { display: flex; flex-direction: column; gap: .75rem; }
.cart-row {
    display: flex; align-items: center; gap: 1rem;
    background: #fff; border-radius: 12px; padding: .85rem 1rem;
    box-shadow: 0 2px 8px rgba(0,0,0,0.06);
}
.cart-img {
    width: 70px; height: 70px; object-fit: cover;
    border-radius: 8px; flex-shrink: 0;
}
.cart-name { flex: 1; }
.cart-name a {
    font-weight: 600; color: #333; text-decoration: none;
    display: block; margin-bottom: .2rem;
}
.cart-name a:hover { color: #8e24aa; }
.cart-unit { font-size: .82rem; color: #999; }
.cart-qty {
    width: 60px; text-align: center; padding: .4rem;
    border: 1.5px solid #ddd; border-radius: 8px; font-size: .95rem;
}
.cart-subtotal {
    font-weight: 700; color: #e91e8c;
    min-width: 100px; text-align: right;
}
.btn-remove {
    background: none; border: none; color: #ccc;
    font-size: 1.1rem; cursor: pointer; padding: .3rem .5rem;
    transition: color .2s;
}
.btn-remove:hover { color: #e53935; }
.cart-footer {
    display: flex; justify-content: space-between;
    align-items: center; margin-top: 1.5rem;
    padding-top: 1.25rem; border-top: 2px solid #f3e5f5;
}
.btn-clear {
    background: none; border: 1.5px solid #ddd;
    color: #888; border-radius: 8px;
    padding: .55rem 1rem; cursor: pointer; transition: all .2s;
}
.btn-clear:hover { border-color: #e53935; color: #e53935; }
.cart-total-area { text-align: right; }
.cart-total { font-size: 1.1rem; margin-bottom: .75rem; }
.cart-total strong { font-size: 1.4rem; color: #e91e8c; }
.btn-checkout {
    display: inline-block;
    background: linear-gradient(90deg,#8e24aa,#e91e8c);
    color: #fff; padding: .75rem 2rem;
    border-radius: 10px; font-weight: 700;
    text-decoration: none; transition: opacity .2s;
}
.btn-checkout:hover { opacity: .9; color: #fff; }
.toast-success {
    background: #e8f5e9; color: #2e7d32;
    padding: .75rem 1rem; border-radius: 8px; margin-bottom: 1rem;
}
</style>
