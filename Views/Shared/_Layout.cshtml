<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — MilkStore</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="preconnect" href="https://fonts.googleapis.com">

    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700;800&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
    <style>
.dot {
  animation: blink 1.4s infinite;
}
.dot:nth-child(2) { animation-delay: 0.2s; }
.dot:nth-child(3) { animation-delay: 0.4s; }

@Html.Raw("@keyframes blink {\n  0%, 80%, 100% { opacity: 0; }\n  40% { opacity: 1; }\n}")
</style>

</head>

<body>

@if (TempData["Success"] != null)
{
    <div id="server-toast" data-message="@TempData["Success"]" data-type="success" style="display:none"></div>
}
@if (TempData["Error"] != null)
{
    <div id="server-toast" data-message="@TempData["Error"]" data-type="error" style="display:none"></div>
}
<div id="page-loader"><div class="spinner"></div></div>

<!-- Top announcement bar -->
<div class="announcement-bar">
    <span>
        <img src="https://cdn-icons-png.flaticon.com/512/3514/3514491.png" alt="delivery" style="width:15px;height:15px;vertical-align:middle;margin-right:6px;filter:brightness(10)">
        Miễn phí giao hàng cho đơn từ 300.000đ &nbsp;|&nbsp;
        <img src="https://cdn-icons-png.flaticon.com/512/1041/1041916.png" alt="star" style="width:14px;height:14px;vertical-align:middle;margin-right:4px;filter:brightness(10)">
        Sản phẩm chính hãng 100%
    </span>
</div>

<nav class="navbar navbar-expand-lg navbar-light bg-white">
    <div class="container">
        <a class="navbar-brand d-flex align-items-center gap-2" asp-area="" asp-controller="Home" asp-action="Index">
                <img src="https://img3.stockfresh.com/files/b/butenkow/m/23/6363960_stock-vector-vector-milk-logo.jpg" alt="MilkStore Logo" style="width:36px; height:36px; border-radius:50%; margin-right:10px">
            <span class="brand-text">MilkStore</span>
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navMenu">
            <ul class="navbar-nav me-auto gap-1">
                <li class="nav-item">
                    <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Trang chủ</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-area="" asp-controller="Product" asp-action="Index">Sản phẩm</a>
                </li>
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">Danh mục</a>
                    <ul class="dropdown-menu dropdown-menu-styled">
                        <li>
                            <a class="dropdown-item" asp-area="" asp-controller="Product" asp-action="Index" asp-route-categoryId="1">
                                 Sữa tươi
                            </a>
                        </li>
                        <li>
                            <a class="dropdown-item" asp-area="" asp-controller="Product" asp-action="Index" asp-route-categoryId="2">
                                 Sữa bột
                            </a>
                        </li>
                        <li>
                            <a class="dropdown-item" asp-area="" asp-controller="Product" asp-action="Index" asp-route-categoryId="3">
                                 Sữa chua
                            </a>
                        </li>
                        <li>
                            <a class="dropdown-item" asp-area="" asp-controller="Product" asp-action="Index" asp-route-categoryId="4">
                                 Sữa đặc
                            </a>
                        </li>
                    </ul>
                </li>
            </ul>

            <form asp-area="" asp-controller="Product" asp-action="Index" method="get" class="d-flex me-3">
                <div class="search-wrap">
                    <img src="https://cdn-icons-png.flaticon.com/512/622/622669.png" alt="search" class="search-icon-img">
                    <input type="text" name="search" placeholder="Tìm sản phẩm..." class="search-input" />
                </div>
            </form>

            <ul class="navbar-nav align-items-center gap-2">
                @{
                    var userId   = Context.Session.GetInt32("UserId");
                    var roleId   = Context.Session.GetInt32("RoleId");
                    var fullName = Context.Session.GetString("FullName");
                }
                @if (userId == null)
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-area="" asp-controller="Account" asp-action="Login">Đăng nhập</a>
                    </li>
                    <li class="nav-item">
                        <a asp-area="" asp-controller="Account" asp-action="Register" class="btn-register">
                            Đăng ký
                        </a>
                    </li>
                }
                else
                {
                    @if (roleId == 1)
                    {
                        <li class="nav-item">
                            <a class="nav-link nav-admin" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                                <img src="https://cdn-icons-png.flaticon.com/512/1828/1828490.png" alt="admin" style="width:16px;height:16px;margin-right:4px;vertical-align:middle"> Admin
                            </a>
                        </li>
                    }
                    <li class="nav-item">
                        <a asp-area="" asp-controller="Cart" asp-action="Index" class="btn-cart-nav">
                            <img src="https://cdn-icons-png.flaticon.com/512/3144/3144456.png" alt="cart" style="width:20px;height:20px">
                            Giỏ hàng
                        </a>
                    </li>
                    <li class="nav-item dropdown">
                        <a href="#" class="nav-link dropdown-toggle user-menu-toggle" data-bs-toggle="dropdown">
                            <div class="user-avatar">
                                @fullName?.Substring(0,1).ToUpper()
                            </div>
                            <span class="user-name-nav">@fullName</span>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end dropdown-menu-styled shadow-sm">
                            <li>
                                <a class="dropdown-item" asp-area="" asp-controller="Account" asp-action="Profile">
                                    <img src="https://cdn-icons-png.flaticon.com/512/1077/1077114.png" alt="" class="dd-icon"> Tài khoản
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item" asp-area="" asp-controller="Order" asp-action="MyOrders">
                                        <img src="https://cdn-icons-png.flaticon.com/512/3144/3144456.png" alt="" class="dd-icon"> Đơn hàng của tôi
                                </a>
                            </li>
                            <li><hr class="dropdown-divider"/></li>
                            <li>
                                <form asp-area="" asp-controller="Account" asp-action="Logout" method="post">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="dropdown-item text-danger">
                                        <img src="https://cdn-icons-png.flaticon.com/512/1828/1828479.png" alt="" class="dd-icon" style="filter:hue-rotate(300deg)"> Đăng xuất
                                    </button>
                                </form>
                            </li>
                        </ul>
                    </li>
                }
            </ul>
        </div>
    </div>
</nav>

<main style="min-height:60vh">@RenderBody()</main>

<footer class="site-footer">
    <div class="container">
        <div class="footer-grid">
            <div class="footer-brand-col">
                <div class="footer-logo">
                        <img src="https://img3.stockfresh.com/files/b/butenkow/m/23/6363960_stock-vector-vector-milk-logo.jpg" alt="MilkStore" style="width:36px;height:36px; border-radius:50%;">
                    <span>MilkStore</span>
                </div>
                <p class="footer-tagline">Cửa hàng sữa uy tín — chất lượng cao — giao hàng nhanh toàn quốc.</p>
                <div class="footer-social">
                        <a href="https://www.facebook.com/" class="social-btn" title="Facebook">
                            <img src="https://z-m-static.xx.fbcdn.net/rsrc.php/yt/r/DUiOg0mJTjz.webp" alt="Facebook" style="width:18px;height:18px;">
                    </a>
                        <a href="https://www.instagram.com/" class="social-btn" title="Instagram">
                            <img src="https://images.vexels.com/media/users/3/137380/isolated/preview/1b2ca367caa7eff8b45c09ec09b44c16-instagram-icon-logo.png" alt="Instagram" style="width:18px;height:18px;">
                    </a>
                        <a href="https://www.youtube.com/" class="social-btn" title="YouTube">
                            <img src="https://cdn-icons-png.freepik.com/256/1383/1383260.png?semt=ais_white_label" alt="YouTube" style="width:18px;height:18px;">
                    </a>
                </div>
            </div>

            <div>
                <div class="footer-heading">Danh mục</div>
                <a class="footer-link" asp-area="" asp-controller="Product" asp-action="Index" asp-route-categoryId="1">Sữa tươi</a>
                <a class="footer-link" asp-area="" asp-controller="Product" asp-action="Index" asp-route-categoryId="2">Sữa bột</a>
                <a class="footer-link" asp-area="" asp-controller="Product" asp-action="Index" asp-route-categoryId="3">Sữa chua</a>
                <a class="footer-link" asp-area="" asp-controller="Product" asp-action="Index" asp-route-categoryId="4">Sữa đặc</a>
            </div>

            <div>
                <div class="footer-heading">Hỗ trợ</div>
                <a class="footer-link" href="#">Chính sách đổi trả</a>
                <a class="footer-link" href="#">Hướng dẫn mua hàng</a>
                <a class="footer-link" href="#">Câu hỏi thường gặp</a>
                <a class="footer-link" href="#">Liên hệ</a>
            </div>

            <div>
                <div class="footer-heading">Liên hệ</div>
                <div class="footer-contact-item">
                    <img src="https://cdn-icons-png.flaticon.com/512/561/561127.png" alt="email" class="footer-contact-icon">
                    <span><a href="/cdn-cgi/l/email-protection" class="__cf_email__" data-cfemail="294a46475d484a5d69444045425a5d465b4c075f47">[email&#160;protected]</a></span>
                </div>
                <div class="footer-contact-item">
                    <img src="https://cdn-icons-png.flaticon.com/512/597/597177.png" alt="phone" class="footer-contact-icon">
                    <span>1800 6789</span>
                </div>
                <div class="footer-contact-item">
                    <img src="https://cdn-icons-png.flaticon.com/512/684/684908.png" alt="location" class="footer-contact-icon">
                    <span>Hà Nội, Việt Nam</span>
                </div>
                <div style="margin-top:1rem">
                    <img src="https://cdn-icons-png.flaticon.com/512/5968/5968756.png" alt="Visa" style="width:36px;height:24px;object-fit:contain;margin-right:8px;background:#fff;border-radius:4px;padding:2px">
                    <img src="https://cdn-icons-png.flaticon.com/512/349/349221.png" alt="Mastercard" style="width:36px;height:24px;object-fit:contain;margin-right:8px;background:#fff;border-radius:4px;padding:2px">
                        <img src="https://rgb.vn/wp-content/uploads/2014/05/rgb_vn_new_branding_paypal_2014_logo_detail.png" alt="PayPal" style="width:36px;height:24px;object-fit:contain;background:#fff;border-radius:4px;padding:2px">
                </div>
            </div>
        </div>

        <div class="footer-bottom">
            <span>© 2025 MilkStore. All rights reserved.</span>
            <span>
                <img src="https://cdn-icons-png.flaticon.com/512/197/197473.png" alt="Vietnam" style="width:18px;height:12px;object-fit:cover;border-radius:2px;margin-right:5px;vertical-align:middle">
                Made in Vietnam
            </span>
        </div>
    </div>
</footer>

<button id="back-to-top" class="back-to-top-btn" title="Lên đầu trang">
    <img src="https://cdn-icons-png.flaticon.com/512/608/608336.png" alt="top" style="width:18px;height:18px;filter:brightness(10)">
</button>

<script data-cfasync="false" src="/cdn-cgi/scripts/5c5dd728/cloudflare-static/email-decode.min.js"></script><script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)


<!-- MilkBot Widget — Shopee Style -->
<style>
#milkbot *{box-sizing:border-box;margin:0;padding:0;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif}
#mb-box{width:340px;border-radius:12px;overflow:hidden;background:#fff;border:1px solid #e0e0e0;flex-direction:column;transform:translateY(16px) scale(0.97);opacity:0;transition:transform .18s ease,opacity .18s ease}
#mb-box.open{transform:translateY(0) scale(1);opacity:1}
.mb-hdr{background:#ee4d2d;padding:9px 12px;display:flex;align-items:center;gap:8px}
.mb-hdr-back{color:#fff;font-size:16px;cursor:pointer;line-height:1;flex-shrink:0}
.mb-hdr-av{width:30px;height:30px;border-radius:50%;background:#fff;display:flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0;border:1.5px solid rgba(255,255,255,0.5)}
.mb-hdr-info{flex:1;min-width:0;overflow:hidden}
.mb-hdr-name{color:#fff;font-size:12px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;line-height:1.3}
.mb-hdr-status{display:flex;align-items:center;gap:4px;font-size:10px;color:rgba(255,255,255,0.9)}
.mb-dot{width:6px;height:6px;border-radius:50%;background:#4cff91;flex-shrink:0}
.mb-hdr-acts{display:flex;gap:10px;flex-shrink:0}
.mb-hdr-acts span{color:#fff;font-size:14px;cursor:pointer}
#mb-msgs{height:260px;overflow-y:auto;padding:10px;display:flex;flex-direction:column;gap:8px;background:#f7f7f7}
.mb-time{text-align:center;font-size:10px;color:#aaa}
.mb-row{display:flex;align-items:flex-end;gap:7px}
.mb-row.me{flex-direction:row-reverse}
.mb-av{width:28px;height:28px;border-radius:50%;background:#ee4d2d;display:flex;align-items:center;justify-content:center;font-size:12px;flex-shrink:0;color:#fff;font-weight:600}
.mb-av.u{background:#1677ff}
.mb-bub{max-width:74%;padding:9px 13px;font-size:13px;line-height:1.55;word-break:break-word}
.mb-bub.bot{background:#fff;color:#222;border-radius:4px 16px 16px 16px;border:0.5px solid #e8e8e8}
.mb-bub.me{background:#ee4d2d;color:#fff;border-radius:16px 4px 16px 16px}
.mb-prod{background:#fff;border-radius:10px;border:0.5px solid #eee;padding:9px 11px;max-width:210px}
.mb-prod .pn{font-size:13px;font-weight:600;color:#222}
.mb-prod .pp{font-size:13px;color:#ee4d2d;margin:3px 0}
.mb-prod .pa{background:#ee4d2d;color:#fff;border:none;border-radius:7px;padding:5px 12px;font-size:12px;cursor:pointer;margin-top:4px}
.mb-qwrap{padding:6px 10px 5px;background:#fff;border-top:0.5px solid #f0f0f0;display:flex;gap:5px;flex-wrap:wrap}
.mb-qbtn{padding:4px 10px;border-radius:20px;border:1px solid #ffcfc7;background:#fff5f3;color:#ee4d2d;font-size:11px;cursor:pointer;transition:background .12s,color .12s;white-space:nowrap}
.mb-qbtn:hover,.mb-qbtn.used{background:#ee4d2d;color:#fff;border-color:#ee4d2d}
.mb-inp-row{display:flex;gap:6px;padding:8px 10px;background:#fff;align-items:center;border-top:1px solid #eee}
.mb-inp-row input{flex:1;border:1px solid #e0e0e0;border-radius:20px;padding:8px 14px;font-size:13px;outline:none;background:#f9f9f9;color:#222}
.mb-inp-row input:focus{border-color:#ee4d2d;background:#fff}
.mb-send{width:36px;height:36px;border-radius:50%;background:#ee4d2d;color:#fff;border:none;font-size:15px;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.mb-tabs{display:flex;background:#fff;border-top:1px solid #eee}
.mb-tab{flex:1;padding:8px 2px 7px;text-align:center;font-size:10px;color:#888;cursor:pointer;border-top:2px solid transparent;display:flex;flex-direction:column;align-items:center;gap:2px;transition:color .15s,border-color .15s}
.mb-tab.on{color:#ee4d2d;border-top-color:#ee4d2d}
.mb-ticon{font-size:16px}
.mb-panel{display:none;background:#fff;flex-direction:column;border-top:0.5px solid #eee}
.mb-panel.on{display:flex}
.mb-ci{display:flex;align-items:center;gap:10px;padding:10px 12px;border-bottom:0.5px solid #f2f2f2}
.mb-ci-img{width:48px;height:48px;border-radius:8px;background:#fff3f0;display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0;border:0.5px solid #ffe0d8}
.mb-ci-name{font-size:13px;font-weight:500;color:#222}
.mb-ci-price{font-size:13px;color:#ee4d2d;margin-top:2px}
.mb-ci-qty{display:flex;align-items:center;gap:7px;margin-top:5px}
.mb-qb2{width:23px;height:23px;border-radius:50%;border:1px solid #ddd;background:#fff;font-size:15px;cursor:pointer;display:flex;align-items:center;justify-content:center;color:#555;line-height:1}
.mb-qval{font-size:13px;min-width:16px;text-align:center;color:#222}
.mb-srow{padding:10px 12px;border-bottom:0.5px solid #f2f2f2;display:flex;align-items:center;gap:10px}
.mb-sico{font-size:18px;width:28px;text-align:center;flex-shrink:0}
.mb-stxt{font-size:13px;color:#222;font-weight:500}
.mb-ssub{font-size:11px;color:#aaa;margin-top:1px}
.mb-sbadge{margin-left:auto;font-size:11px;padding:3px 8px;border-radius:10px;background:#fff3f0;color:#ee4d2d;border:0.5px solid #ee4d2d;white-space:nowrap}
.mb-orow{padding:10px 12px;border-bottom:0.5px solid #f2f2f2;display:flex;align-items:center;gap:10px}
.mb-onum{font-size:11px;color:#aaa;margin-top:1px}
.mb-ostatus{font-size:11px;padding:2px 8px;border-radius:10px;margin-left:auto;white-space:nowrap}
.mb-ostatus.w{background:#fff7e6;color:#d48806}
.mb-ostatus.s{background:#e6f7ff;color:#1677ff}
.mb-ostatus.d{background:#f6ffed;color:#389e0d}
.mb-cart-foot{padding:10px 12px;display:flex;align-items:center;justify-content:space-between;border-top:1px solid #eee}
.mb-ctotal{font-size:13px;color:#555}
.mb-ctotal strong{color:#ee4d2d}
.mb-cbuy{background:#ee4d2d;color:#fff;border:none;border-radius:8px;padding:8px 18px;font-size:13px;cursor:pointer;font-weight:500}
.mb-typing{font-size:11px;color:#aaa;padding:2px 4px}
#mb-toggle-btn{width:56px;height:56px;border-radius:50%;background:#ee4d2d;color:#fff;border:none;font-size:24px;cursor:pointer;box-shadow:0 2px 8px rgba(238,77,45,0.35)}
</style>

<div id="milkbot" style="position:fixed;bottom:24px;right:24px;z-index:9999;display:flex;flex-direction:column;align-items:flex-end;gap:10px">
  <div id="mb-box" style="display:none">
    <div class="mb-hdr">
      <div class="mb-hdr-back" onclick="toggleBot()">‹</div>
      <div class="mb-hdr-av">🥛</div>
      <div class="mb-hdr-info">
        <div class="mb-hdr-name">Mai — Tư vấn sữa MilkStore</div>
        <div class="mb-hdr-status"><div class="mb-dot"></div>Đang trực tuyến • Phản hồi ngay</div>
      </div>
      <div class="mb-hdr-acts"><span>📞</span><span onclick="toggleBot()">✕</span></div>
    </div>

    <div id="mb-msgs">
      <div class="mb-time">Hôm nay @DateTime.Now.ToString("HH:mm")</div>
      <div class="mb-row">
        <div class="mb-av">M</div>
        <div class="mb-bub bot">Xin chào! Mình là Mai 😊 Bạn đang cần tư vấn sữa gì ạ? Nhấn gợi ý bên dưới hoặc nhập câu hỏi nhé!</div>
      </div>
    </div>

    <div class="mb-qwrap" id="mb-qwrap">
      <button class="mb-qbtn" onclick="mbQs(this)">Sữa bé sơ sinh</button>
      <button class="mb-qbtn" onclick="mbQs(this)">Sữa tăng cân</button>
      <button class="mb-qbtn" onclick="mbQs(this)">Sữa tiểu đường</button>
      <button class="mb-qbtn" onclick="mbQs(this)">Sữa ít đường</button>
      <button class="mb-qbtn" onclick="mbQs(this)">Sữa hữu cơ</button>
      <button class="mb-qbtn" onclick="mbQs(this)">Sữa cho mẹ bầu</button>
    </div>

    <div class="mb-inp-row">
      <input id="mb-inp" placeholder="Nhập tin nhắn..." onkeydown="if(event.key==='Enter')mbSend()"/>
      <button class="mb-send" onclick="mbSend()">➤</button>
    </div>

    <div class="mb-tabs">
      <div class="mb-tab on" onclick="mbTab(0,this)"><div class="mb-ticon">💬</div>Chat</div>
      <div class="mb-tab" onclick="mbTab(1,this)"><div class="mb-ticon">🛒</div>Giỏ hàng</div>
      <div class="mb-tab" onclick="mbTab(2,this)"><div class="mb-ticon">🚚</div>Vận chuyển</div>
      <div class="mb-tab" onclick="mbTab(3,this)"><div class="mb-ticon">📦</div>Đơn hàng</div>
    </div>

    <div class="mb-panel on" id="mb-p0"></div>

    <div class="mb-panel" id="mb-p1">
      <div class="mb-ci">
        <div class="mb-ci-img">🍼</div>
        <div style="flex:1">
          <div class="mb-ci-name">Vinamilk 100% Tươi 1L</div>
          <div class="mb-ci-price">30.000đ / hộp</div>
          <div class="mb-ci-qty">
            <button class="mb-qb2" onclick="mbChg(0,-1)">−</button>
            <span class="mb-qval" id="mbq0">2</span>
            <button class="mb-qb2" onclick="mbChg(0,1)">+</button>
          </div>
        </div>
      </div>
      <div class="mb-ci">
        <div class="mb-ci-img">🥛</div>
        <div style="flex:1">
          <div class="mb-ci-name">TH True Milk Ít Đường 1L</div>
          <div class="mb-ci-price">35.000đ / hộp</div>
          <div class="mb-ci-qty">
            <button class="mb-qb2" onclick="mbChg(1,-1)">−</button>
            <span class="mb-qval" id="mbq1">1</span>
            <button class="mb-qb2" onclick="mbChg(1,1)">+</button>
          </div>
        </div>
      </div>
      <div class="mb-ci">
        <div class="mb-ci-img">🌿</div>
        <div style="flex:1">
          <div class="mb-ci-name">Organic Dalat Milk 500ml</div>
          <div class="mb-ci-price">45.000đ / hộp</div>
          <div class="mb-ci-qty">
            <button class="mb-qb2" onclick="mbChg(2,-1)">−</button>
            <span class="mb-qval" id="mbq2">1</span>
            <button class="mb-qb2" onclick="mbChg(2,1)">+</button>
          </div>
        </div>
      </div>
      <div class="mb-cart-foot">
        <div class="mb-ctotal">Tổng: <strong id="mb-tot">140.000đ</strong></div>
        <button class="mb-cbuy" onclick="window.location.href='/Cart/Index'">Đặt hàng ngay</button>
      </div>
    </div>

    <div class="mb-panel" id="mb-p2">
      <div class="mb-srow"><div class="mb-sico">🚚</div><div><div class="mb-stxt">Giao hàng tiêu chuẩn</div><div class="mb-ssub">Dự kiến 2–3 ngày làm việc</div></div><div class="mb-sbadge">Miễn phí</div></div>
      <div class="mb-srow"><div class="mb-sico">⚡</div><div><div class="mb-stxt">Giao hàng nhanh</div><div class="mb-ssub">Nhận trong ngày (trước 21:00)</div></div><div class="mb-sbadge">15.000đ</div></div>
      <div class="mb-srow"><div class="mb-sico">🏍️</div><div><div class="mb-stxt">Giao siêu tốc</div><div class="mb-ssub">Nhận trong 2 giờ</div></div><div class="mb-sbadge">25.000đ</div></div>
      <div class="mb-srow"><div class="mb-sico">📍</div><div><div class="mb-stxt">Địa chỉ giao hàng</div><div class="mb-ssub">Hà Nội, Việt Nam</div></div></div>
      <div class="mb-srow"><div class="mb-sico">🏪</div><div><div class="mb-stxt">Nhận tại cửa hàng</div><div class="mb-ssub">Miễn phí — 12 điểm gần bạn</div></div></div>
    </div>

    <div class="mb-panel" id="mb-p3">
      <div class="mb-orow"><div class="mb-sico">🕐</div><div style="flex:1"><div class="mb-stxt">Đơn #MK8821</div><div class="mb-onum">Vinamilk 1L x2 · 60.000đ</div></div><div class="mb-ostatus w">Chờ xác nhận</div></div>
      <div class="mb-orow"><div class="mb-sico">🚚</div><div style="flex:1"><div class="mb-stxt">Đơn #MK7743</div><div class="mb-onum">TH True Milk x3 · 105.000đ</div></div><div class="mb-ostatus s">Đang giao</div></div>
      <div class="mb-orow"><div class="mb-sico">✅</div><div style="flex:1"><div class="mb-stxt">Đơn #MK6612</div><div class="mb-onum">Organic Dalat x1 · 45.000đ</div></div><div class="mb-ostatus d">Đã nhận hàng</div></div>
      <div class="mb-orow"><div class="mb-sico">✅</div><div style="flex:1"><div class="mb-stxt">Đơn #MK5501</div><div class="mb-onum">Vinamilk x4 · 120.000đ</div></div><div class="mb-ostatus d">Đã nhận hàng</div></div>
    </div>
  </div>

  <button id="mb-toggle-btn" onclick="toggleBot()">🥛</button>
</div>

<script>
const MB_SERVER = "https://milkbot.onrender.com";
const mbSid = Math.random().toString(36).slice(2);
let mbOpen = false;

function toggleBot() {
  const box = document.getElementById('mb-box');
  mbOpen = !mbOpen;
  if (mbOpen) {
    box.style.display = 'flex';
    setTimeout(() => box.classList.add('open'), 10);
  } else {
    box.classList.remove('open');
    setTimeout(() => { box.style.display = 'none'; }, 200);
  }
}

const mbQmap = {
  'sữa bé sơ sinh': 'Với bé sơ sinh, mình gợi ý Nan Optipro 1 hoặc Similac Gain IQ ạ 🍼 Bé được bao nhiêu tháng tuổi rồi?',
  'sữa tăng cân': 'Bạn muốn tăng cân cho bé hay người lớn ạ? Mình có Pediasure (bé 1-10 tuổi) và Ensure Gold (người lớn) 💪',
  'sữa tiểu đường': 'Dạ mình gợi ý Glucerna SR hoặc Diasure — ít đường, chỉ số GI thấp, tốt cho người tiểu đường ạ 😊',
  'sữa ít đường': 'TH True Milk Ít Đường và Vinamilk Không Đường đều rất ngon ạ! Hộp 1L từ 28.000đ thôi 🥛',
  'sữa hữu cơ': 'Organic Dalat Milk và Lothamilk Organic đang rất hot ạ! Sữa sạch, không chất bảo quản 🌿',
  'sữa cho mẹ bầu': 'Mình gợi ý Enfamama A+ hoặc Friso Mom cho mẹ bầu và cho con bú ạ. Bạn đang mang thai tháng thứ mấy? 🤱'
};

function mbAddMsg(text, role) {
  const msgs = document.getElementById('mb-msgs');
  const row = document.createElement('div');
  row.className = 'mb-row' + (role === 'user' ? ' me' : '');
  const av = document.createElement('div');
  av.className = 'mb-av' + (role === 'user' ? ' u' : '');
  av.textContent = role === 'user' ? 'B' : 'M';
  const bub = document.createElement('div');
  bub.className = 'mb-bub ' + (role === 'user' ? 'me' : 'bot');
  bub.textContent = text;
  if (role === 'user') { row.appendChild(bub); row.appendChild(av); }
  else { row.appendChild(av); row.appendChild(bub); }
  msgs.appendChild(row);
  msgs.scrollTop = msgs.scrollHeight;
}

function mbShowProds(products) {
  const msgs = document.getElementById('mb-msgs');
  products.forEach(p => {
    const row = document.createElement('div');
    row.className = 'mb-row';
    const av = document.createElement('div'); av.className = 'mb-av'; av.textContent = 'M';
    const card = document.createElement('div'); card.className = 'mb-prod';
    card.innerHTML = `<div class="pn">${p.name}</div><div class="pp">${p.price.toLocaleString('vi-VN')}đ</div><button class="pa">🛒 Thêm vào giỏ</button>`;
    card.querySelector('button').onclick = () => { window.location.href = '/Cart/Add/' + p.id; };
    row.appendChild(av); row.appendChild(card);
    msgs.appendChild(row);
  });
  msgs.scrollTop = msgs.scrollHeight;
}

function mbQs(btn) {
  btn.classList.add('used');
  const txt = btn.textContent;
  mbAddMsg(txt, 'user');
  const key = txt.toLowerCase();
  setTimeout(() => {
    const reply = mbQmap[key] || 'Mình sẽ tư vấn ngay ạ! Bạn có thể cho mình biết thêm nhu cầu cụ thể không? 😊';
    mbAddMsg(reply, 'bot');
    mbShowProds([{ id: 1, name: 'Vinamilk 100% Tươi 1L', price: 30000 }, { id: 2, name: 'TH True Milk Ít Đường 1L', price: 35000 }]);
  }, 700);
}

async function mbSend() {
  const inp = document.getElementById('mb-inp');
  const msg = inp.value.trim();
  if (!msg) return;
  inp.value = '';
  mbAddMsg(msg, 'user');
  const t = document.createElement('div');
  t.className = 'mb-typing'; t.id = 'mb-typing';
  t.innerHTML = 'Mai đang nhập <span class="dot">.</span><span class="dot">.</span><span class="dot">.</span>';
  document.getElementById('mb-msgs').appendChild(t);
  document.getElementById('mb-msgs').scrollTop = 9999;
  try {
    const r = await fetch(MB_SERVER + '/chat', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ sessionId: mbSid, message: msg })
    });
    const data = await r.json();
    document.getElementById('mb-typing')?.remove();
    mbAddMsg(data.reply, 'bot');
    if (data.products) mbShowProds(data.products);
  } catch (e) {
    document.getElementById('mb-typing')?.remove();
    mbAddMsg('Xin lỗi, mình đang bận. Vui lòng thử lại!', 'bot');
  }
}

const mbQQs = [2, 1, 1], mbPPs = [30000, 35000, 45000];
function mbChg(i, d) {
  mbQQs[i] = Math.max(1, mbQQs[i] + d);
  document.getElementById('mbq' + i).textContent = mbQQs[i];
  const tot = mbQQs[0]*mbPPs[0] + mbQQs[1]*mbPPs[1] + mbQQs[2]*mbPPs[2];
  document.getElementById('mb-tot').textContent = tot.toLocaleString('vi-VN') + 'đ';
}

function mbTab(n, el) {
  document.querySelectorAll('.mb-tab').forEach(t => t.classList.remove('on'));
  el.classList.add('on');
  document.querySelectorAll('.mb-panel').forEach((p, i) => p.classList.toggle('on', i === n));
}

window.addEventListener('load', () => { setTimeout(toggleBot, 1500); });
</script>

</body>
</html>
