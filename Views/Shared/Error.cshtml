@{
    ViewData["Title"] = "Lỗi";
    Layout = "~/Views/Shared/_Layout.cshtml";
    int code = ViewBag.Code ?? 500;
}
<div style="min-height:60vh;display:flex;align-items:center;justify-content:center;text-align:center;padding:2rem">
    <div>
        <div style="font-size:6rem;font-weight:900;background:linear-gradient(135deg,#8e24aa,#e91e8c);-webkit-background-clip:text;-webkit-text-fill-color:transparent;line-height:1">@code</div>
        <h2 style="font-size:1.5rem;font-weight:700;color:#333;margin:1rem 0 .5rem">
            @(code == 404 ? "Không tìm thấy trang" : "Lỗi máy chủ")
        </h2>
        <p style="color:#888;margin-bottom:2rem">
            @(code == 404 ? "Trang bạn tìm không tồn tại." : "Đã có lỗi xảy ra. Vui lòng thử lại.")
        </p>
        <a asp-area="" asp-controller="Home" asp-action="Index"
           style="background:linear-gradient(90deg,#8e24aa,#e91e8c);color:#fff;padding:.75rem 2rem;border-radius:10px;font-weight:700;text-decoration:none;font-size:.95rem">
            ← Về trang chủ
        </a>
    </div>
</div>
