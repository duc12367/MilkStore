@{
    ViewData["Title"] = "Lay lai mat khau";
    Layout = "_Layout";
}
<div style="min-height:60vh;display:flex;align-items:center;justify-content:center;padding:2rem">
    <div style="background:#fff;border-radius:20px;box-shadow:0 8px 40px rgba(0,0,0,.1);padding:2.5rem 2rem;width:100%;max-width:420px">
        <h2 style="font-size:1.4rem;font-weight:800;color:#1a3a2a;margin-bottom:.5rem">🔑 Lay lai mat khau</h2>
        @if (ViewBag.Msg != null)
        {
            <div style="background:#f0fff4;border:1px solid #a8e6c0;border-radius:10px;padding:.75rem 1rem;color:#1a6b3c;font-weight:600;margin-bottom:1rem">
                ✅ @ViewBag.Msg
            </div>
            <a asp-action="Login" style="color:#1a3a2a;font-weight:700">← Quay lai dang nhap</a>
        }
        else
        {
            <p style="color:#888;font-size:.9rem;margin-bottom:1.5rem">Nhap email da dang ky de nhan link dat lai mat khau.</p>
            <form method="post">
                @Html.AntiForgeryToken()
                <div style="margin-bottom:1rem">
                    <label style="font-weight:700;font-size:.88rem;color:#444;display:block;margin-bottom:.4rem">Email</label>
                    <input type="email" name="email" required placeholder="example@gmail.com"
                           style="width:100%;padding:.75rem 1rem;border:1.5px solid #e0e6ea;border-radius:12px;font-size:.95rem;box-sizing:border-box" />
                </div>
                <button type="submit"
                        style="width:100%;padding:.85rem;border:none;border-radius:12px;background:linear-gradient(135deg,#1a3a2a,#2d5a40);color:#fff;font-size:1rem;font-weight:800;cursor:pointer">
                    Gui email dat lai mat khau
                </button>
            </form>
        }
    </div>
</div>
