@{
    ViewData["Title"] = "Đăng nhập";
    <link rel="icon" type="image/png" href="~/images/logo-transparent.png" />
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>Đăng nhập — MilkStore</title>
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Nunito',sans-serif;min-height:100vh;display:flex;background:#f0f7f2}
.auth-left{
    flex:1;background:linear-gradient(145deg,#0f2018 0%,#1a3a2a 50%,#2d5a40 100%);
    display:flex;flex-direction:column;align-items:center;justify-content:center;
    padding:3rem 2rem;position:relative;overflow:hidden;
}
.auth-left::before{
    content:'';position:absolute;top:-80px;right:-80px;
    width:320px;height:320px;border-radius:50%;
    background:rgba(255,255,255,.04);
}
.auth-left::after{
    content:'';position:absolute;bottom:-100px;left:-60px;
    width:280px;height:280px;border-radius:50%;
    background:rgba(255,255,255,.03);
}
.brand-logo{display:flex;align-items:center;gap:.8rem;margin-bottom:3rem;z-index:1}
.brand-logo img{width:54px;height:54px;border-radius:50%;border:3px solid rgba(255,255,255,.25)}
.brand-logo span{font-size:1.6rem;font-weight:800;color:#fff;letter-spacing:-.5px}
.auth-illustration{z-index:1;text-align:center;margin-bottom:2.5rem}
.auth-illustration img{width:280px;max-width:90%;border-radius:20px;box-shadow:0 20px 60px rgba(0,0,0,.3);opacity:.9}
.auth-left-text{z-index:1;text-align:center;color:#fff}
.auth-left-text h2{font-size:1.6rem;font-weight:800;margin-bottom:.75rem;line-height:1.3}
.auth-left-text p{font-size:.92rem;opacity:.7;line-height:1.7;max-width:320px}
.trust-badges{display:flex;gap:1rem;margin-top:1.75rem;flex-wrap:wrap;justify-content:center;z-index:1}
.trust-badge{
    background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.15);
    border-radius:20px;padding:.4rem .9rem;font-size:.78rem;color:rgba(255,255,255,.85);
    display:flex;align-items:center;gap:.4rem;font-weight:600;
}

.auth-right{
    width:480px;flex-shrink:0;display:flex;align-items:center;justify-content:center;
    padding:2rem;background:#fff;
}
.auth-form-wrap{width:100%;max-width:400px}
.auth-form-wrap h1{font-size:1.75rem;font-weight:800;color:#1a1a1a;margin-bottom:.4rem}
.auth-form-wrap .sub{font-size:.9rem;color:#888;margin-bottom:2rem}
.auth-form-wrap .sub a{color:#1a3a2a;font-weight:700;text-decoration:none}
.auth-form-wrap .sub a:hover{text-decoration:underline}

.social-row{display:flex;gap:.75rem;margin-bottom:1.5rem}
.social-btn{
    flex:1;display:flex;align-items:center;justify-content:center;gap:.5rem;
    padding:.7rem;border-radius:12px;border:1.5px solid #e0e6ea;
    font-size:.85rem;font-weight:700;cursor:pointer;
    background:#fff;transition:all .2s;color:#333;
}
.social-btn:hover{background:#f8f9fb;border-color:#c0c8d0;transform:translateY(-1px)}
.social-btn img{width:18px;height:18px}

.divider{display:flex;align-items:center;gap:.75rem;margin-bottom:1.5rem}
.divider::before,.divider::after{content:'';flex:1;height:1px;background:#e8ecef}
.divider span{font-size:.8rem;color:#aaa;font-weight:600;white-space:nowrap}

.field{margin-bottom:1.1rem}
.field label{display:block;font-size:.85rem;font-weight:700;color:#444;margin-bottom:.4rem}
.field-wrap{position:relative}
.field-wrap input{
    width:100%;padding:.75rem 1rem;padding-right:2.8rem;
    border:1.5px solid #e0e6ea;border-radius:12px;
    font-size:.95rem;font-family:'Nunito',sans-serif;
    color:#222;background:#fafbfc;transition:border-color .2s,background .2s;outline:none;
}
.field-wrap input:focus{border-color:#1a3a2a;background:#fff}
.field-wrap input::placeholder{color:#bbb}
.field-icon{position:absolute;right:.9rem;top:50%;transform:translateY(-50%);opacity:.4;cursor:pointer;font-size:1rem}
.field-row{display:flex;justify-content:space-between;align-items:center;margin-bottom:.4rem}
.field-row label{font-size:.85rem;font-weight:700;color:#444}
.forgot-link{font-size:.82rem;color:#1a3a2a;font-weight:700;text-decoration:none}
.forgot-link:hover{text-decoration:underline}

.err-box{
    background:#fff0f0;border:1px solid #ffc5c5;border-radius:10px;
    padding:.65rem 1rem;font-size:.85rem;color:#c0392b;
    margin-bottom:1rem;display:flex;align-items:center;gap:.5rem;
}

.btn-submit{
    width:100%;padding:.85rem;border:none;border-radius:12px;
    background:linear-gradient(135deg,#1a3a2a,#2d5a40);
    color:#fff;font-size:1rem;font-weight:800;cursor:pointer;
    font-family:'Nunito',sans-serif;
    transition:transform .2s,box-shadow .2s;margin-top:.5rem;
}
.btn-submit:hover{transform:translateY(-2px);box-shadow:0 8px 24px rgba(26,58,42,.3)}
.btn-submit:active{transform:translateY(0)}

@@media(max-width:768px){
    body{flex-direction:column}
    .auth-left{padding:2rem 1.5rem;min-height:auto}
    .auth-illustration img{width:180px}
    .auth-left-text h2{font-size:1.3rem}
    .auth-right{width:100%;padding:1.5rem}
}
    </style>
</head>
<body>

<div class="auth-left">
    <div class="brand-logo">
        <img src="https://img3.stockfresh.com/files/b/butenkow/m/23/6363960_stock-vector-vector-milk-logo.jpg" alt="MilkStore">
        <span>MilkStore</span>
    </div>
    <div class="auth-illustration">
        <img src="https://i.ibb.co/XN4wFm7/anh.png" alt="Milk products"
             onerror="this.src='https://placehold.co/280x200/1a3a2a/ffffff?text=MilkStore'">
    </div>
    <div class="auth-left-text">
        <h2>Sữa sạch cho cả gia đình 🥛</h2>
        <p>Hàng trăm sản phẩm chính hãng — giao hàng nhanh — giá tốt nhất thị trường.</p>
        <div class="trust-badges">
            <div class="trust-badge">✅ 100% chính hãng</div>
            <div class="trust-badge">🚚 Miễn phí ship</div>
            <div class="trust-badge">⭐ 4.8/5 đánh giá</div>
        </div>
    </div>
</div>

<div class="auth-right">
    <div class="auth-form-wrap">
        <h1>Chào mừng trở lại!</h1>
        <p class="sub">Chưa có tài khoản? <a asp-controller="Account" asp-action="Register">Đăng ký miễn phí</a></p>

        <div class="social-row">
            <button class="social-btn" onclick="alert('Tính năng đang phát triển!')">
                <img src="https://cdn-icons-png.flaticon.com/512/2991/2991148.png" alt="Google">
                Google
            </button>
            <button class="social-btn" onclick="alert('Tính năng đang phát triển!')">
                <img src="https://cdn-icons-png.flaticon.com/512/733/733547.png" alt="Facebook">
                Facebook
            </button>
        </div>

        <div class="divider"><span>hoặc đăng nhập bằng email</span></div>

        @if (ViewBag.Error != null)
        {
            <div class="err-box">⚠️ @ViewBag.Error</div>
        }

        <form method="post" asp-action="Login">
            @Html.AntiForgeryToken()
            <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl"/>

            <div class="field">
                <label>Email</label>
                <div class="field-wrap">
                    <input type="email" name="email" placeholder="email@example.com" required autocomplete="email"/>
                    <span class="field-icon">📧</span>
                </div>
            </div>

            <div class="field">
                <div class="field-row">
                    <label>Mật khẩu</label>
                    <a href="#" class="forgot-link" onclick="showForgot(event)">Quên mật khẩu?</a>
                </div>
                <div class="field-wrap">
                    <input type="password" name="password" id="pw" placeholder="••••••••" required autocomplete="current-password"/>
                    <span class="field-icon" onclick="togglePw()">👁️</span>
                </div>
            </div>

            <button type="submit" class="btn-submit">Đăng nhập →</button>
        </form>
    </div>
</div>

<!-- Modal quên mật khẩu -->
<div id="forgot-modal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:9999;align-items:center;justify-content:center">
    <div style="background:#fff;border-radius:20px;padding:2rem;width:90%;max-width:400px;box-shadow:0 24px 60px rgba(0,0,0,.2)">
        <h3 style="font-size:1.2rem;font-weight:800;margin-bottom:.5rem">🔑 Lấy lại mật khẩu</h3>
        <p style="font-size:.88rem;color:#888;margin-bottom:1.25rem">Nhập email đã đăng ký, mình sẽ gửi link đặt lại mật khẩu.</p>
        <input id="forgot-email" type="email" placeholder="Email của bạn..."
            style="width:100%;padding:.75rem 1rem;border:1.5px solid #e0e6ea;border-radius:12px;font-size:.95rem;font-family:'Nunito',sans-serif;outline:none;margin-bottom:1rem"/>
        <div style="display:flex;gap:.75rem">
            <button onclick="closeForgot()" style="flex:1;padding:.7rem;border:1.5px solid #e0e6ea;border-radius:10px;background:#fff;cursor:pointer;font-weight:600;font-family:'Nunito',sans-serif">Huỷ</button>
            <button onclick="sendForgot()" style="flex:1;padding:.7rem;border:none;border-radius:10px;background:#1a3a2a;color:#fff;cursor:pointer;font-weight:700;font-family:'Nunito',sans-serif">Gửi email</button>
        </div>
        <p id="forgot-msg" style="font-size:.83rem;margin-top:.75rem;color:#1a6b3c;display:none;font-weight:600"></p>
    </div>
</div>

<script>
function togglePw(){
    const pw = document.getElementById('pw');
    pw.type = pw.type === 'password' ? 'text' : 'password';
}
function showForgot(e){
    e.preventDefault();
    const m = document.getElementById('forgot-modal');
    m.style.display = 'flex';
}
function closeForgot(){
    document.getElementById('forgot-modal').style.display = 'none';
    document.getElementById('forgot-msg').style.display = 'none';
}
async function sendForgot(){
    const email = document.getElementById('forgot-email').value.trim();
    if (!email) return;
    const msg = document.getElementById('forgot-msg');
    msg.style.display = 'block';
    msg.style.color = '#1a6b3c';
    msg.textContent = ' Nếu email tồn tại, chúng mình sẽ gửi link đặt lại mật khẩu trong vài phút!';
}
</script>
</body>
</html>
