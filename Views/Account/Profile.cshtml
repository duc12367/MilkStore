@model MilkStore.Models.User
@{
    ViewData["Title"] = "Tài khoản của tôi";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5" style="max-width:620px">
    @if (TempData["Success"] != null)
    {
        <div class="alert-ok">✓ @TempData["Success"]</div>
    }

    <div class="profile-card">
        <div class="profile-header">
            <div class="avatar-xl">@Model.FullName.Substring(0,1).ToUpper()</div>
            <div>
                <h2>@Model.FullName</h2>
                <span class="role-pill @(Model.RoleId == 1 ? "admin" : "user")">
                    @(Model.RoleId == 1 ? " Admin" : " Khách hàng")
                </span>
            </div>
        </div>

        <div class="profile-body">
           <div class="info-row">
                <span class="lbl">
                <img src="https://cdn-icons-png.flaticon.com/512/561/561127.png"
                style="width:16px; height:16px; margin-right:6px; vertical-align:middle;">
                 Email
                </span>
                <span>@Model.Email</span>
           </div>
            <div class="info-row"><span class="lbl">
                <img src="https://cdn-icons-png.flaticon.com/512/684/684908.png"
                style="width:16px; height:16px; margin-right:6px; vertical-align:middle;">
                 Địa chỉ
                </span>
                <span>@(Model.Address ?? "Chưa cập nhật")</span>
            </div>
            <div class="info-row"><span class="lbl">
                <img src="https://cdn-icons-png.flaticon.com/512/597/597177.png"
                style="width:16px; height:16px; margin-right:6px; vertical-align:middle;">
                 SĐT
                </span>
                <span>@(Model.Phone ?? "Chưa cập nhật")</span>
            </div>
        </div>

        <!-- Form chỉnh sửa -->
        <div class="profile-edit">
            <h5> Chỉnh sửa thông tin</h5>
            <form asp-action="UpdateProfile" method="post">
                @Html.AntiForgeryToken()
                <div class="fe-group">
                    <label>Họ và tên</label>
                    <input type="text" name="fullName" value="@Model.FullName" class="fe-ctrl" required />
                </div>
                <div class="fe-row">
                    <div class="fe-group">
                        <label>Địa chỉ</label>
                        <input type="text" name="address" value="@Model.Address" class="fe-ctrl" placeholder="TP.HCM" />
                    </div>
                    <div class="fe-group">
                        <label>Điện thoại</label>
                        <input type="tel" name="phone" value="@Model.Phone" class="fe-ctrl" placeholder="09xxxxxxxx" />
                    </div>
                </div>
                <button type="submit" class="btn-save"> Lưu thay đổi</button>
            </form>
        </div>

        <div class="profile-actions">
            <a asp-controller="Order" asp-action="MyOrders" class="btn-orders"> Đơn hàng của tôi</a>
        </div>
    </div>
</div>

<style>
.alert-ok { background:#e8f5e9;color:#1b5e20;padding:.75rem 1rem;border-radius:8px;margin-bottom:1rem;border-left:4px solid #43a047; }
.profile-card { background:#fff;border-radius:16px;box-shadow:0 4px 24px rgba(0,0,0,.08);overflow:hidden; }
.profile-header { background:linear-gradient(135deg,#8e24aa,#e91e8c);padding:2rem;display:flex;align-items:center;gap:1.2rem;color:#fff; }
.avatar-xl { width:64px;height:64px;background:rgba(255,255,255,.25);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:1.8rem;font-weight:700;flex-shrink:0; }
.profile-header h2 { margin:0;font-size:1.3rem; }
.role-pill { display:inline-block;padding:.2rem .75rem;border-radius:20px;font-size:.8rem;font-weight:600;margin-top:.3rem; }
.role-pill.admin { background:#fff3e0;color:#e65100; }
.role-pill.user  { background:#e8f5e9;color:#2e7d32; }
.profile-body { padding:1.25rem 1.5rem; }
.info-row { display:flex;align-items:center;gap:1rem;padding:.6rem 0;border-bottom:1px solid #f5f5f5; }
.lbl { font-size:.85rem;font-weight:600;color:#888;min-width:120px; }
.profile-edit { padding:1.25rem 1.5rem;background:#faf5ff;border-top:1px solid #f3e5f5; }
.profile-edit h5 { font-weight:700;margin-bottom:1rem;color:#333; }
.fe-group { margin-bottom:.85rem; }
.fe-group label { display:block;font-size:.875rem;font-weight:600;color:#555;margin-bottom:.3rem; }
.fe-ctrl { width:100%;padding:.6rem .9rem;border:1.5px solid #e0e0e0;border-radius:8px;font-size:.95rem;box-sizing:border-box; }
.fe-ctrl:focus { outline:none;border-color:#8e24aa; }
.fe-row { display:flex;gap:1rem; }
.fe-row .fe-group { flex:1; }
.btn-save { background:linear-gradient(90deg,#8e24aa,#e91e8c);color:#fff;border:none;border-radius:8px;padding:.65rem 1.5rem;font-weight:700;cursor:pointer; }
.profile-actions { padding:1.25rem 1.5rem;border-top:1px solid #f3e5f5;display:flex;gap:1rem; }
.btn-orders { background:#f3e5f5;color:#6a1b9a;border-radius:8px;padding:.6rem 1.25rem;font-weight:600;text-decoration:none; }
</style>
